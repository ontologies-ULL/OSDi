@prefix : <https://w3id.org/ontologies-ULL/OSDi#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/ontologies-ULL/OSDi#> .

<https://w3id.org/ontologies-ULL/OSDi> rdf:type owl:Ontology ;
                                        owl:versionIRI <https://w3id.org/ontologies-ULL/OSDi/1.1> ;
                                        <http://creativecommons.org/ns#license> <http://creativecommons.org/licenses/by-nc-sa/4.0/> ;
                                        <http://purl.org/dc/elements/1.1/contributor> "María Luz Couce Pico (https://orcid.org/0000-0003-4861-9905)" ;
                                        <http://purl.org/dc/elements/1.1/creator> "David Prieto González (https://orcid.org/0000-0003-1411-129X)" ,
                                                                                  "Evelio J. González González (https://orcid.org/0000-0002-2203-3757)" ,
                                                                                  "Iván Castilla Rodríguez (http://orcid.org/0000-0003-3933-2582)" ;
                                        <http://purl.org/dc/elements/1.1/description> "Ontology designed for collecting and inferring the parameters required to create a simulation-based Health Technology Assesment"@en ,
                                                                                      "Ontología diseñada para recopilar e inferir los parámetros necesarios para crear una evaluación de tecnología sanitaria basada en simulación"@es ;
                                        <http://purl.org/dc/elements/1.1/source> <https://github.com/ontologies-ULL/OSDi> ;
                                        <http://purl.org/dc/terms/abstract> "This ontology provides a structured framework for the interoperability of health economics data used to create models. The ontology represents all the concepts and relationships involved in health technology assessment, including the characterization of the disease and its development, the population affected, and the interventions applied."@en ;
                                        rdfs:label "OSDi"@en ,
                                                   "OSDi"@es ;
                                        owl:versionInfo "1.1" .

#################################################################
#    Annotation properties
#################################################################

###  http://ainf.aau.at/ontodebug#testCase
<http://ainf.aau.at/ontodebug#testCase> rdf:type owl:AnnotationProperty .


###  http://creativecommons.org/ns#license
<http://creativecommons.org/ns#license> rdf:type owl:AnnotationProperty .


###  http://ontologydesignpatterns.org/opla-sd#entityPosition
<http://ontologydesignpatterns.org/opla-sd#entityPosition> rdf:type owl:AnnotationProperty .


###  http://ontologydesignpatterns.org/opla-sd#entityPositionX
<http://ontologydesignpatterns.org/opla-sd#entityPositionX> rdf:type owl:AnnotationProperty .


###  http://ontologydesignpatterns.org/opla-sd#entityPositionY
<http://ontologydesignpatterns.org/opla-sd#entityPositionY> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/contributor
<http://purl.org/dc/elements/1.1/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/source
<http://purl.org/dc/elements/1.1/source> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/abstract
<http://purl.org/dc/terms/abstract> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
<http://www.w3.org/2004/02/skos/core#definition> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
<http://www.w3.org/2004/02/skos/core#prefLabel> rdf:type owl:AnnotationProperty .


###  https://w3id.org/ontologies-ULL/OSDi#TODO
:TODO rdf:type owl:AnnotationProperty .


###  https://w3id.org/ontologies-ULL/OSDi#contributor
:contributor rdf:type owl:AnnotationProperty .


###  https://w3id.org/ontologies-ULL/OSDi#creator
:creator rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#broader
<http://www.w3.org/2004/02/skos/core#broader> rdf:type owl:ObjectProperty ,
                                                       owl:TransitiveProperty .


###  http://www.w3.org/2004/02/skos/core#inScheme
<http://www.w3.org/2004/02/skos/core#inScheme> rdf:type owl:ObjectProperty .


###  http://www.w3.org/2004/02/skos/core#topConceptOf
<http://www.w3.org/2004/02/skos/core#topConceptOf> rdf:type owl:ObjectProperty .


###  https://w3id.org/ontologies-ULL/OSDi#affects
:affects rdf:type owl:ObjectProperty ;
         owl:inverseOf :isAffectedBy ;
         rdfs:domain :Effect ;
         rdfs:range [ rdf:type owl:Class ;
                      owl:unionOf ( :Attribute
                                    :Parameter
                                  )
                    ] ;
         rdfs:comment "Defines a relationship between an effect and an attribute or parameter, indicating that the effect affects the attribute or parameter."@en ;
         rdfs:label "afecta"@es ,
                    "affects"@en .


###  https://w3id.org/ontologies-ULL/OSDi#affectsProgressionElement
:affectsProgressionElement rdf:type owl:ObjectProperty ;
                           rdfs:domain :ProgressionCombinationRule ;
                           rdfs:range :ClinicalProgressionElement ;
                           rdfs:comment "Defines the combination rule that affects certain progression element"@en ;
                           rdfs:label "afecta al elemento de progresión"@es ,
                                      "affects progression element"@en .


###  https://w3id.org/ontologies-ULL/OSDi#belongsToGroup
:belongsToGroup rdf:type owl:ObjectProperty ;
                owl:inverseOf :hasGroupItem ;
                rdfs:domain :GroupableModelItem ;
                rdfs:range :Group ;
                rdfs:comment "Indicates that a model item belongs to a group, which can be used to define the strategies that are applied to a health condition, intervention or strategy, as well as the strategies that are part of a group of strategies."@en ;
                rdfs:label "belongs to group"@en ,
                           "pertenece al grupo"@es .


###  https://w3id.org/ontologies-ULL/OSDi#causesFailOf
:causesFailOf rdf:type owl:ObjectProperty ;
              owl:inverseOf :failsIf ;
              rdfs:domain :Parameter ;
              rdfs:range :LineOfTherapy ;
              rdfs:comment "Defines the condition (expressed as any type of parameter) upon which certain strategy fails and must progress to the next step"@en ;
              rdfs:label "causa el fallo de"@es ,
                         "causes fail of"@en .


###  https://w3id.org/ontologies-ULL/OSDi#dependsOn
:dependsOn rdf:type owl:ObjectProperty ;
           owl:inverseOf :hasDependantCalculatedParameter ;
           rdfs:domain :CalculatedParameter ;
           rdfs:range [ rdf:type owl:Class ;
                        owl:unionOf ( :Attribute
                                      :Parameter
                                    )
                      ] ;
           rdfs:comment "Defines a relationship between a Valuable instance and an Attribute, where the \"hasExpression\" of the domain instance makes reference to the range instance. Hence, the hasExpression property should include a reference to that attribute, so that the final value of this Valuable is a function of the value of this attribute."@en ;
           rdfs:label "depende del atributo"@es ,
                      "depends on attribute"@en .


###  https://w3id.org/ontologies-ULL/OSDi#detects
:detects rdf:type owl:ObjectProperty ;
         owl:inverseOf :isDetectedBy ;
         rdfs:domain [ rdf:type owl:Class ;
                       owl:unionOf ( :DetectionIntervention
                                     :DetectionStrategy
                                   )
                     ] ;
         rdfs:range :Disease ;
         rdfs:comment "Indicates the disease detected by a detection intervention"@en ;
         rdfs:label "detecta"@es ,
                    "detects"@en .


###  https://w3id.org/ontologies-ULL/OSDi#failsIf
:failsIf rdf:type owl:ObjectProperty ;
         rdfs:domain :LineOfTherapy ;
         rdfs:range :Parameter ;
         rdfs:comment "Defines the condition (expressed as any type of parameter) upon which certain strategy fails and must progress to the next step"@en ;
         rdfs:label "fails if"@en ,
                    "falla si"@es .


###  https://w3id.org/ontologies-ULL/OSDi#followedByStrategy
:followedByStrategy rdf:type owl:ObjectProperty ;
                    owl:inverseOf :followsStrategy ;
                    rdfs:domain :Strategy ;
                    rdfs:range :Strategy ;
                    rdfs:comment "Defines the relationship between two strategies, where one is followed by the other."@en ;
                    rdfs:label "followed by strategy"@en ,
                               "seguido por la estrategia"@es .


###  https://w3id.org/ontologies-ULL/OSDi#followsStrategy
:followsStrategy rdf:type owl:ObjectProperty ;
                 rdfs:domain :Strategy ;
                 rdfs:range :Strategy ;
                 rdfs:comment "Defines the relationship between two strategies, where one follows the other."@en ;
                 rdfs:label "follows strategy"@en ,
                            "sigue la estrategia"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasAge
:hasAge rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :usesAttributeValue ;
        rdfs:domain :Population ;
        rdfs:range [ rdf:type owl:Restriction ;
                     owl:onProperty :isValueOfAttribute ;
                     owl:hasValue :Attribute_Age
                   ] ;
        rdfs:comment "Defines the age of the population, which can be used to define the characteristics of the disease and the interventions. The value is the average age of the individuals in the population."@en ;
        rdfs:label "has age"@en ,
                   "tiene edad"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasAttributeValue
:hasAttributeValue rdf:type owl:ObjectProperty ;
                   owl:inverseOf :isValueOfAttribute ;
                   rdfs:domain :Attribute ;
                   rdfs:range :Parameter ;
                   rdfs:comment "Defines a value for an attribute, which should be used by a population and/or disease"@en ;
                   rdfs:label "has attribute value"@en ,
                              "tiene el valor del atributo"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasCategory
:hasCategory rdf:type owl:ObjectProperty ;
             rdfs:domain [ rdf:type owl:Class ;
                           owl:unionOf ( :Cost
                                         :Intervention
                                         :ResourceUsageItem
                                       )
                         ] ;
             rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
             rdfs:comment "Asocia un coste o una estrategia con un concepto SKOS usado con fines de clasificación y análisis."@es ,
                          "Associates a cost or a strategy with a SKOS concept used for classification and analysis purposes."@en ;
             rdfs:label "has category"@en ,
                        "tiene categoría"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasConditionExpression
:hasConditionExpression rdf:type owl:ObjectProperty ;
                        owl:inverseOf :isConditionExpressionOf ;
                        rdfs:domain [ rdf:type owl:Class ;
                                      owl:unionOf ( :Guideline
                                                    :Strategy
                                                  )
                                    ] ;
                        rdfs:range :Parameter ;
                        rdfs:comment "It allows expressing conditions based on parameters that we will find in the model. For example, we can find that certain drugs will be administered depending on the weight or age of the patient."@en ;
                        rdfs:label "has condition expression"@en ,
                                   "tiene la expresión de condición"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasCost
:hasCost rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :hasParameter ;
         rdfs:domain [ rdf:type owl:Class ;
                       owl:unionOf ( :HealthCondition
                                     :HealthTechnology
                                     :Intervention
                                     :Pathway
                                     :Strategy
                                   )
                     ] ;
         rdfs:range :Cost ;
         rdfs:comment "Defines the cost of a health condition, health technology, intervention, pathway or strategy."@en ;
         rdfs:label "has cost"@en ,
                    "tiene el coste"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasDataItemType
:hasDataItemType rdf:type owl:ObjectProperty ;
                 owl:inverseOf :isDataItemTypeOf ;
                 rdfs:domain :Parameter ;
                 rdfs:range :DataItemType ;
                 rdfs:comment "Defines the type of data item that represents the parameter, which can be used to determine how to use the parameter in the model and how to obtain its value."@en ;
                 rdfs:label "has data item type"@en ,
                            "tiene el tipo de datos"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasDependantCalculatedParameter
:hasDependantCalculatedParameter rdf:type owl:ObjectProperty ;
                                 rdfs:domain [ rdf:type owl:Class ;
                                               owl:unionOf ( :Attribute
                                                             :Parameter
                                                           )
                                             ] ;
                                 rdfs:range :CalculatedParameter ;
                                 rdfs:comment "Defines a calculated parameter that depends on other parameters."@en ;
                                 rdfs:label "has dependant calculated parameter"@en ,
                                            "tiene el parámetro calculado dependiente"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasDose
:hasDose rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :hasParameter ;
         rdfs:domain :Guideline ;
         rdfs:range :Parameter ;
         rdfs:comment "Defines the dosage of the indicated drug"@en ;
         rdfs:label "has dose"@en ,
                    "tiene la dosis"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasDuration
:hasDuration rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasParameter ;
             rdfs:domain :ClinicalProgressionElement ;
             rdfs:range :Parameter ;
             rdfs:comment "Defines the duration of a certain manifestation of the disease, or the duration of an intervention, etc. This value must be expressed in number of years."@en ;
             rdfs:label "has duration"@en ,
                        "tiene la duración"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasEffect
:hasEffect rdf:type owl:ObjectProperty ;
           owl:inverseOf :isEffectOf ;
           rdfs:domain [ rdf:type owl:Class ;
                         owl:unionOf ( :HealthCondition
                                       :Intervention
                                       :Pathway
                                       :Population
                                       :ResourceUsageItem
                                     )
                       ] ;
           rdfs:range :Effect ;
           rdfs:comment "Defines a relationship between a health condition, intervention, pathway, population or resource usage item and an effect, indicating that the health condition, intervention, pathway, population or resource usage item has a certain effect on the disease progression or on the patients."@en ;
           rdfs:label "has effect"@en ,
                      "tiene el efecto"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasEffectMagnitude
:hasEffectMagnitude rdf:type owl:ObjectProperty ;
                    rdfs:domain :Effect ;
                    rdfs:range :Parameter ;
                    rdfs:comment "Defines the parameter that defines the magnitude of the effect"@en ;
                    rdfs:label "has magnitude effect"@en ,
                               "tiene magnitud del efecto"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasEndAge
:hasEndAge rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :hasParameter ;
           rdfs:domain :ClinicalProgressionElement ;
           rdfs:range :Parameter ;
           rdfs:comment "Defines the age at which a certain condition or disease ends."@en ;
           rdfs:label "has end age"@en ,
                      "tiene la edad de finalización"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasEpidemiologicalParameter
:hasEpidemiologicalParameter rdf:type owl:ObjectProperty ;
                             rdfs:subPropertyOf :hasParameter ;
                             rdfs:domain [ rdf:type owl:Class ;
                                           owl:unionOf ( :Disease
                                                         :Population
                                                       )
                                         ] ;
                             rdfs:range :EpidemiologicalParameter ;
                             rdfs:comment "Defines an epidemiological parameter of a disease or a population, such as the incidence, prevalence, mortality, etc."@en ;
                             rdfs:label "has epidemiological parameter"@en ,
                                        "tiene el parámetro epidemiológico"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasExpressionLanguage
:hasExpressionLanguage rdf:type owl:ObjectProperty ;
                       owl:inverseOf :isExpressionLanguageOf ;
                       rdfs:domain :CalculatedParameter ;
                       rdfs:range :ExpressionLanguage ;
                       rdfs:comment "Defines the expression language used in a calculated parameter, which can be any formal language that allows us to express mathematical formulas, such as MathML or OpenMath."@en ;
                       rdfs:label "has expression language"@en ,
                                  "tiene el lenguage de expresión"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasFirst
:hasFirst rdf:type owl:ObjectProperty ;
          rdfs:domain :SequentialCombinationRule ;
          rdfs:range :OrderedModelItem ;
          rdfs:comment "Points to the first of a set of ordered items"@en ;
          rdfs:label "has first"@en ,
                     "tiene primero"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasFrequency
:hasFrequency rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :hasParameter ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( :AcuteManifestation
                                          :Guideline
                                        )
                          ] ;
              rdfs:range :Parameter ;
              rdfs:comment "Indicates the time cycle of how often the treatment, the follow-up test or their respective strategies have to be applied. In the case of a manifestation of the disease, it will indicate how many times a year the symptom manifests itself."@en ;
              rdfs:label "has frequency"@en ,
                         "tiene la frecuencia"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasGroupItem
:hasGroupItem rdf:type owl:ObjectProperty ;
              rdfs:domain :Group ;
              rdfs:range :GroupableModelItem ;
              rdfs:comment "Describes the items of a group"@en ;
              rdfs:label "has group item"@en ,
                         "tiene el elemento del grupo"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasGuideline
:hasGuideline rdf:type owl:ObjectProperty ;
              owl:inverseOf :isGuidelineOf ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( :HealthTechnology
                                          :Strategy
                                        )
                          ] ;
              rdfs:range :Guideline ;
              rdfs:comment "Defines a relationship between a health technology or a strategy and a guideline, indicating that the guideline is applied to the health technology or strategy."@en ;
              rdfs:label "has guideline"@en ,
                         "tiene la pauta"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasInitialProportion
:hasInitialProportion rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :hasParameter ;
                      rdfs:domain [ rdf:type owl:Class ;
                                    owl:unionOf ( :ChronicManifestation
                                                  :Development
                                                  :Population
                                                  :Stage
                                                )
                                  ] ;
                      rdfs:range :Parameter ;
                      rdfs:comment "Defines the initial proportion of patients of a population that already present certain manifestation"@en ;
                      rdfs:label "has initial proportion"@en ,
                                 "tiene la proporción inicial"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasIntervention
:hasIntervention rdf:type owl:ObjectProperty ;
                 owl:inverseOf :isInterventionOf ;
                 rdfs:domain :Disease ;
                 rdfs:range :Intervention ;
                 rdfs:comment "Defines a relationship between a disease and an intervention, indicating that the intervention is applied to the disease."@en ;
                 rdfs:label "has intervention"@en ,
                            "tiene la intervención"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasLifeExpectancy
:hasLifeExpectancy rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :hasParameter ;
                   rdfs:domain :Population ;
                   rdfs:range :Parameter ;
                   rdfs:comment "Defines the life expectancy of the population, which is the average number of years that an individual of the population is expected to live. This value must be expressed in number of years."@en ;
                   rdfs:label "has life expectancy"@en ,
                              "tiene la esperanza de vida"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasNext
:hasNext rdf:type owl:ObjectProperty ;
         owl:inverseOf :hasPrevious ;
         rdfs:domain :OrderedModelItem ;
         rdfs:range :OrderedModelItem ;
         rdfs:comment "Points to the next ordered model item"@en ;
         rdfs:label "has next"@en ,
                    "tiene siguiente"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasOnsetAge
:hasOnsetAge rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasParameter ;
             rdfs:domain :ClinicalProgressionElement ;
             rdfs:range :Parameter ;
             rdfs:comment "Defines the age at which a certain manifestation of the disease appears. This value must be expressed in number of years."@en ;
             rdfs:label "has onset age"@en ,
                        "tiene la edad de inicio"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasParameter
:hasParameter rdf:type owl:ObjectProperty ;
              owl:inverseOf :isParameterOf ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( :ClinicalProgressionElement
                                          :Disease
                                          :Intervention
                                          :Pathway
                                          :Population
                                          :ResourceUsageItem
                                        )
                          ] ;
              rdfs:range :Parameter ;
              rdfs:comment "Defines a relationship between a disease, intervention, pathway, population or resource usage item and a parameter, indicating that the parameter is used to characterize the disease, intervention, pathway, population or resource usage item."@en ;
              rdfs:label "has parameter"@en ,
                         "tiene el parámetro"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasPrevious
:hasPrevious rdf:type owl:ObjectProperty ;
             rdfs:domain :OrderedModelItem ;
             rdfs:range :OrderedModelItem ;
             rdfs:comment "Points to the previous ordered model item"@en ;
             rdfs:label "has previous"@en ,
                        "tiene anterior"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasProgressionElement
:hasProgressionElement rdf:type owl:ObjectProperty ;
                       owl:inverseOf :isProgressionElementOf ;
                       rdfs:domain [ rdf:type owl:Class ;
                                     owl:unionOf ( :Disease
                                                   :ProgressionCombinationRule
                                                 )
                                   ] ;
                       rdfs:range :DiseaseProgressionElement ;
                       rdfs:comment "Defines a relationship between a disease and its progression element, indicating that an individual affected by the disease can have the progression element."@en ;
                       rdfs:label "has progression element"@en ,
                                  "has progression element"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasProportionWithinGroup
:hasProportionWithinGroup rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf :hasParameter ;
                          rdfs:domain :GroupableModelItemWithProportion ;
                          rdfs:range :Parameter ;
                          rdfs:comment "Defines the proportion of patients that present a certain characteristic within a group. For example, the proportion of patients that present a certain manifestation within a stage of the disease, or the proportion of patients that receive a certain intervention within a strategy."@en ;
                          rdfs:label "has proportion within group"@en ,
                                     "tiene la proporción dentro del grupo"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasRiskCharacterization
:hasRiskCharacterization rdf:type owl:ObjectProperty ;
                         owl:inverseOf :isRiskCharacterizationOf ;
                         rdfs:domain :ClinicalProgressionElement ;
                         rdfs:range [ rdf:type owl:Class ;
                                      owl:unionOf ( :Parameter
                                                    :Pathway
                                                  )
                                    ] ;
                         rdfs:comment "Defines the risk characterization of a clinical progression element, which can be expressed as a parameter (e.g., relative risk) or as a pathway (e.g., a pathway that defines the events that lead to the occurrence of a certain manifestation)."@en ;
                         rdfs:label "has risk characterization"@en ,
                                    "tiene la caracterización de riesgo"@es ;
                         :TODO "Check if this is the best name for the property" .


###  https://w3id.org/ontologies-ULL/OSDi#hasSensitivity
:hasSensitivity rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :hasParameter ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( :DetectionIntervention
                                            :DetectionStrategy
                                          )
                            ] ;
                rdfs:range :Parameter ;
                rdfs:comment "The Sensitivity in epidemiology is the Probability of correctly classifying a sick individual, that is, the Probability that a positive result will be obtained in a diagnostic test for a sick subject. The Sensitivity is, therefore, the ability of the complementary test to detect the disease. Sensitivity is the percentage of true positives or the Probability that the test is positive if the disease is present; False negatives are sick subjects diagnosed as healthy." ;
                rdfs:label "has sensitivity"@en ,
                           "tiene la sensibilidad"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasSex
:hasSex rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :usesAttributeValue ;
        rdfs:domain :Population ;
        rdfs:range [ rdf:type owl:Restriction ;
                     owl:onProperty :isValueOfAttribute ;
                     owl:hasValue :Attribute_Sex
                   ] ;
        rdfs:comment "Defines the sex of the population, which can be used to define the characteristics of the disease and the interventions. The value is the proportion of female individuals in the population."@en ;
        rdfs:label "has sex"@en ,
                   "tiene sexo"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasSpecificity
:hasSpecificity rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :hasParameter ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( :DetectionIntervention
                                            :DetectionStrategy
                                          )
                            ] ;
                rdfs:range :Parameter ;
                rdfs:comment "The Specificity of a test is the Probability that a healthy subject will have a negative test result. Specificity is the percentage of true negatives or the Probability that the test will be negative if the disease is not present. False positives are healthy subjects diagnosed as sick." ;
                rdfs:label "has specificity"@en ,
                           "tiene la especificidad"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasStrategy
:hasStrategy rdf:type owl:ObjectProperty ;
             owl:inverseOf :isStrategyOf ;
             rdfs:domain [ rdf:type owl:Class ;
                           owl:unionOf ( :HealthCondition
                                         :Intervention
                                         :Strategy
                                       )
                         ] ;
             rdfs:range [ rdf:type owl:Class ;
                          owl:unionOf ( :Strategy
                                        [ owl:intersectionOf ( :Group
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty :hasGroupItem ;
                                                                 owl:allValuesFrom :Strategy
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ]
                                      )
                        ] ;
             rdfs:comment "Defines a relationship between a health condition, intervention or strategy and a strategy, which can be either a simple strategy or a group of strategies. This property allows us to define the strategies that are applied to a health condition, intervention or strategy, as well as the strategies that are part of a group of strategies."@en ;
             rdfs:label "has strategy"@en ,
                        "tiene la estrategia"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasSubProgression
:hasSubProgression rdf:type owl:ObjectProperty ;
                   rdfs:domain :ClinicalProgressionElement ;
                   rdfs:range :ClinicalProgressionElement ;
                   rdfs:comment "Defines a relationship between a clinical progression element and its sub-element, indicating that the sub-element only appear as a part of the clinical progression."@en ;
                   rdfs:label "has sub-progression"@en ,
                              "has sub-progression"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasSubpopulation
:hasSubpopulation rdf:type owl:ObjectProperty ;
                  owl:inverseOf :isSubpopulationOf ;
                  rdfs:domain :Population ;
                  rdfs:range :Population ;
                  rdfs:comment "Defines a relationship between a population and a subpopulation, indicating that the subpopulation is a subset of the population."@en ;
                  rdfs:label "has subpopulation"@en ,
                             "tiene la subpoblación"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasTemporaryThreshold
:hasTemporaryThreshold rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf :hasParameter ;
                       rdfs:domain [ rdf:type owl:Class ;
                                     owl:unionOf ( :ScreeningIntervention
                                                   :ScreeningStrategy
                                                 )
                                   ] ;
                       rdfs:range :Parameter ;
                       rdfs:comment "Time limit in which the sample must be made. For example on the third day of birth. This value must be expressed in number of days." ;
                       rdfs:label "has temporary threshold"@en ,
                                  "tiene el umbral temporal"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasUncertaintyCharacterization
:hasUncertaintyCharacterization rdf:type owl:ObjectProperty ;
                                owl:inverseOf :isUncertaintyCharacterizationOf ;
                                rdfs:domain [ rdf:type owl:Class ;
                                              owl:unionOf ( :FirstOrderUncertaintyParameter
                                                            :SecondOrderUncertaintyParameter
                                                          )
                                            ] ;
                                rdfs:range [ rdf:type owl:Class ;
                                             owl:unionOf ( :Parameter
                                                           :ProbabilityDistributionExpression
                                                         )
                                           ] ;
                                rdfs:comment "Defines the uncertainty characterization of a parameter, which can be expressed as another parameter (e.g., confidence interval) or as a probability distribution expression."@en ;
                                rdfs:label "has uncertainty characterization"@en ,
                                           "tiene la caracterización de incertidumbre"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasUtility
:hasUtility rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :hasParameter ;
            rdfs:domain [ rdf:type owl:Class ;
                          owl:unionOf ( :HealthCondition
                                        :Intervention
                                        :Pathway
                                        :Population
                                        :ResourceUsageItem
                                      )
                        ] ;
            rdfs:range :Utility ;
            rdfs:comment "Defines the utility associated with a health condition, intervention, pathway, population or resource usage item. The utility is a measure of the preference or value that individuals or society assign to a particular health state or outcome. It is often used in health economics and decision analysis to evaluate the desirability of different health outcomes and to inform healthcare decision-making."@en ;
            rdfs:label "has utility"@en ,
                       "tiene la utilidad"@es .


###  https://w3id.org/ontologies-ULL/OSDi#includedByModel
:includedByModel rdf:type owl:ObjectProperty ;
                 owl:inverseOf :includesModelItem ;
                 rdfs:domain :ModelItem ;
                 rdfs:range :Model ;
                 rdfs:comment "Defines a relationship between a model item and a model, indicating that the model item is included as part of the structure or content of the model."@en ;
                 rdfs:label "included by model"@en ,
                            "incluido por el modelo"@es .


###  https://w3id.org/ontologies-ULL/OSDi#includesModelItem
:includesModelItem rdf:type owl:ObjectProperty ;
                   rdfs:domain :Model ;
                   rdfs:range :ModelItem ;
                   rdfs:comment "Defines a relationship between a model and a model item, indicating that the model includes that item as part of its structure or content."@en ;
                   rdfs:label "includes model item"@en ,
                              "incluye el elemento del modelo"@es .


###  https://w3id.org/ontologies-ULL/OSDi#isAffectedBy
:isAffectedBy rdf:type owl:ObjectProperty ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( :Attribute
                                          :Parameter
                                        )
                          ] ;
              rdfs:range :Effect ;
              rdfs:comment "Defines a relationship between an attribute or parameter and an effect, indicating that the attribute or parameter is affected by that effect."@en ;
              rdfs:label "es modificado por"@es ,
                         "is modified by"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isConditionExpressionOf
:isConditionExpressionOf rdf:type owl:ObjectProperty ;
                         rdfs:domain :Parameter ;
                         rdfs:range [ rdf:type owl:Class ;
                                      owl:unionOf ( :Guideline
                                                    :Strategy
                                                  )
                                    ] ;
                         rdfs:comment "Defines a relationship between a condition expression and a guideline or strategy, indicating that the condition expression is used within the guideline or strategy."@en ;
                         rdfs:label "es expresión de condición de"@es ,
                                    "is condition expression of"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isDataItemTypeOf
:isDataItemTypeOf rdf:type owl:ObjectProperty ;
                  rdfs:domain :DataItemType ;
                  rdfs:range :Parameter ;
                  rdfs:comment "Defines a relationship between a data item type and a parameter, indicating that the data item type is used to define the parameter."@en ;
                  rdfs:label "es tipo de elemento de datos de"@es ,
                             "is data item type of"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isDetectedBy
:isDetectedBy rdf:type owl:ObjectProperty ;
              rdfs:domain :Disease ;
              rdfs:range [ rdf:type owl:Class ;
                           owl:unionOf ( :DetectionIntervention
                                         :DetectionStrategy
                                       )
                         ] ;
              rdfs:comment "Defines a relationship between a detection strategy or intervention and a disease, indicating that such estrategy or intervention is used to identify the disease."@en ;
              rdfs:label "es detectado por"@es ,
                         "is detected by"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isEffectOf
:isEffectOf rdf:type owl:ObjectProperty ;
            rdfs:domain :Effect ;
            rdfs:range [ rdf:type owl:Class ;
                         owl:unionOf ( :HealthCondition
                                       :Intervention
                                       :Pathway
                                       :Population
                                       :ResourceUsageItem
                                     )
                       ] ;
            rdfs:comment "Defines a relationship between an effect and a health condition, intervention, pathway, population or resource usage item, indicating that the effect is associated with that element."@en ;
            rdfs:label "es efecto de"@es ,
                       "is effect of"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isExpressionLanguageOf
:isExpressionLanguageOf rdf:type owl:ObjectProperty ;
                        rdfs:domain :ExpressionLanguage ;
                        rdfs:range :CalculatedParameter ;
                        rdfs:comment "Defines a relationship between an expression language and a calculated parameter, indicating that the expression language is used to define the calculated parameter."@en ;
                        rdfs:label "es lenguaje de expresión de"@es ,
                                   "is expression language of"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isGuidelineOf
:isGuidelineOf rdf:type owl:ObjectProperty ;
               rdfs:domain :Guideline ;
               rdfs:range [ rdf:type owl:Class ;
                            owl:unionOf ( :HealthTechnology
                                          :Strategy
                                        )
                          ] ;
               rdfs:comment "Defines a relationship between a guideline and a health technology or strategy, indicating that the guideline is associated with that technology or strategy."@en ;
               rdfs:label "es guía o pauta de"@es ,
                          "is guideline of"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isInterventionOf
:isInterventionOf rdf:type owl:ObjectProperty ;
                  rdfs:domain :Intervention ;
                  rdfs:range :Disease ;
                  rdfs:comment "Defines a relationship between an intervention and a disease, indicating that the intervention is used to treat the disease."@en ;
                  rdfs:label "es intervención de"@es ,
                             "is intervention of"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isParameterOf
:isParameterOf rdf:type owl:ObjectProperty ;
               rdfs:domain :Parameter ;
               rdfs:range [ rdf:type owl:Class ;
                            owl:unionOf ( :ClinicalProgressionElement
                                          :Disease
                                          :Intervention
                                          :Pathway
                                          :Population
                                          :ResourceUsageItem
                                        )
                          ] ;
               rdfs:comment "Defines a relationship between a parameter and a clinical progression element, disease, intervention, pathway, population or resource usage item, indicating that the parameter is associated with that element."@en ;
               rdfs:label "es parámetro de"@es ,
                          "is parameter of"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isProgressionElementOf
:isProgressionElementOf rdf:type owl:ObjectProperty ;
                        rdfs:domain :DiseaseProgressionElement ;
                        rdfs:range [ rdf:type owl:Class ;
                                     owl:unionOf ( :Disease
                                                   :ProgressionCombinationRule
                                                 )
                                   ] ;
                        rdfs:comment "Defines a relationship between a disease progression element and a disease or progression combination rule."@en ;
                        rdfs:label "es elemento de progresión de"@es ,
                                   "is progression element of"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isRequiredBy
:isRequiredBy rdf:type owl:ObjectProperty ;
              owl:inverseOf :requires ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( :ClinicalProgressionElement
                                          :Intervention
                                        )
                          ] ;
              rdfs:range :Pathway ;
              rdfs:comment "Defines a relationship between a clinical progression element and a pathway, indicating that the element is required by the pathway."@en ;
              rdfs:label "es requerido por"@es ,
                         "is required by"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isRiskCharacterizationOf
:isRiskCharacterizationOf rdf:type owl:ObjectProperty ;
                          rdfs:domain [ rdf:type owl:Class ;
                                        owl:unionOf ( :Parameter
                                                      :Pathway
                                                    )
                                      ] ;
                          rdfs:range :ClinicalProgressionElement ;
                          rdfs:comment "Defines a relationship between a risk characterization and a clinical progression element, indicating that the characterization applies to that element."@en ;
                          rdfs:label "es caracterización de riesgo de"@es ,
                                     "is risk characterization of"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isStrategyOf
:isStrategyOf rdf:type owl:ObjectProperty ;
              rdfs:domain :Strategy ;
              rdfs:comment "Defines a relationship between a strategy and a pathway, indicating that the strategy is used in the pathway."@en ;
              rdfs:label "es estrategia de"@es ,
                         "is strategy of"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isSubpopulationOf
:isSubpopulationOf rdf:type owl:ObjectProperty ;
                   rdfs:domain :Population ;
                   rdfs:range :Population ;
                   rdfs:comment "Defines a relationship between two populations, indicating that the domain population is a subpopulation of the range population."@en ;
                   rdfs:label "es subpoblación de"@es ,
                              "is subpopulation of"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isSupersededByClinicalProgression
:isSupersededByClinicalProgression rdf:type owl:ObjectProperty ;
                                   owl:inverseOf :supersedesClinicalProgression ;
                                   rdfs:domain :ClinicalProgressionElement ;
                                   rdfs:range :ClinicalProgressionElement ;
                                   rdfs:comment "Defines a relationship between two clinical progression elements, indicating that the domain element is superseded by the range element."@en ;
                                   rdfs:label "es reemplazado por"@es ,
                                              "is superseded by"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isUncertaintyCharacterizationOf
:isUncertaintyCharacterizationOf rdf:type owl:ObjectProperty ;
                                 rdfs:domain [ rdf:type owl:Class ;
                                               owl:unionOf ( :Parameter
                                                             :ProbabilityDistributionExpression
                                                           )
                                             ] ;
                                 rdfs:range [ rdf:type owl:Class ;
                                              owl:unionOf ( :FirstOrderUncertaintyParameter
                                                            :SecondOrderUncertaintyParameter
                                                          )
                                            ] ;
                                 rdfs:comment "Defines a relationship between an uncertainty characterization and a parameter or probability distribution expression, indicating that the characterization applies to that element."@en ;
                                 rdfs:label "es caracterización de incertidumbre de"@es ,
                                            "is uncertainty characterization of"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isUsedAsAttributeValueBy
:isUsedAsAttributeValueBy rdf:type owl:ObjectProperty ;
                          owl:inverseOf :usesAttributeValue ;
                          rdfs:domain :AttributeValueParameter ;
                          rdfs:range [ rdf:type owl:Class ;
                                       owl:unionOf ( :Disease
                                                     :Population
                                                   )
                                     ] ;
                          rdfs:comment "Defines a relationship between an attribute value parameter and a disease or population, indicating that the parameter is used as an attribute value for that disease or population."@en ;
                          rdfs:label "es utilizado como valor de atributo por"@es ,
                                     "is used as attribute value by"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isUsedByStrategy
:isUsedByStrategy rdf:type owl:ObjectProperty ;
                  owl:inverseOf :usesHealthTechnology ;
                  rdfs:domain :HealthTechnology ;
                  rdfs:range :Strategy ;
                  rdfs:comment "Defines a relationship between a health technology and a strategy, indicating that the health technology is used in that strategy."@en ;
                  rdfs:label "es utilizado por la estrategia"@es ,
                             "is used by strategy"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isValueOfAttribute
:isValueOfAttribute rdf:type owl:ObjectProperty ;
                    rdfs:domain :Parameter ;
                    rdfs:range :Attribute ;
                    rdfs:comment "Defines a relationship between a parameter and an attribute, indicating that the parameter is a value of that attribute."@en ;
                    rdfs:label "es valor del atributo"@es ,
                               "is value of attribute"@en .


###  https://w3id.org/ontologies-ULL/OSDi#requires
:requires rdf:type owl:ObjectProperty ;
          rdfs:domain :Pathway ;
          rdfs:range [ rdf:type owl:Class ;
                       owl:unionOf ( :ClinicalProgressionElement
                                     :Intervention
                                   )
                     ] ;
          rdfs:comment "Defines that a pathway requires a certain clinical progression element or intervention. This can be useful for defining that a certain pathway requires the presence of a certain symptom or only appears when a certain intervention is applied."@en ;
          rdfs:label "requiere"@es ,
                     "requires"@en .


###  https://w3id.org/ontologies-ULL/OSDi#supersedesClinicalProgression
:supersedesClinicalProgression rdf:type owl:ObjectProperty ;
                               rdfs:domain :ClinicalProgressionElement ;
                               rdfs:range :ClinicalProgressionElement ;
                               rdfs:comment "Defines that a clinical progression element replaces another one. This can be useful for defining that a certain manifestation replaces another one in the progression of the disease, for example, to define that a certain symptom appears after the disappearance of another symptom."@en ;
                               rdfs:label "reemplaza la progresión clínica"@es ,
                                          "supersedes clinical progression"@en .


###  https://w3id.org/ontologies-ULL/OSDi#usesAttributeValue
:usesAttributeValue rdf:type owl:ObjectProperty ;
                    rdfs:domain [ rdf:type owl:Class ;
                                  owl:unionOf ( :Disease
                                                :Population
                                              )
                                ] ;
                    rdfs:range :AttributeValueParameter ;
                    rdfs:comment "Defines a relationship between a disease or population and a parameter which is the value of an attribute"@en ;
                    rdfs:label "usa el valor del atributo"@es ,
                               "uses attribute value"@en .


###  https://w3id.org/ontologies-ULL/OSDi#usesHealthTechnology
:usesHealthTechnology rdf:type owl:ObjectProperty ;
                      rdfs:domain :Strategy ;
                      rdfs:range :HealthTechnology ;
                      rdfs:comment "Defines a relationship between a strategy and a health technology used in that strategy. This is useful for defining the health technologies used in a strategy, for example, to define that a certain drug is used in a treatment strategy or that a certain screening test is used in a screening strategy."@en ;
                      rdfs:label "uses health technology"@en ,
                                 "utiliza tecnología sanitaria"@es .


###  https://w3id.org/ontologies-ULL/OSDi#usesModel
:usesModel rdf:type owl:ObjectProperty ;
           rdfs:domain :Experiment ;
           rdfs:range :Model ;
           rdfs:comment "An experiment uses certain model"@en ;
           rdfs:label "usa el modelo"@es ,
                      "uses model"@en .


###  https://w3id.org/ontologies-ULL/OSDi#usesSameModelItemsAs
:usesSameModelItemsAs rdf:type owl:ObjectProperty ;
                      rdfs:domain :Model ;
                      rdfs:range :Model ;
                      rdfs:comment "Defines that a model uses the same data items as another model. Useful for avoiding \"recreating\" that relationship for all the model items in models which are very similar and simply difer in some characteristics."@en ;
                      rdfs:label "uses same model items as"@en ,
                                 "utiliza los mismos elementos del modelo que"@es .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/ontologies-ULL/OSDi#appliesOneTime
:appliesOneTime rdf:type owl:DatatypeProperty ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( :Cost
                                            :Utility
                                          )
                            ] ;
                rdfs:range xsd:boolean ;
                rdfs:comment "Defines the temporal behavior of a parameter (generally a cost or utility): if true, applies upon onset of some model item (disease, disease progression...); otherwise, it is assumed to apply annually."@en ;
                rdfs:label "applies one time"@en ,
                           "se aplica una única vez"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasAlfaParameter
:hasAlfaParameter rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf :hasProbabilityDistributionParameter ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( :BetaDistributionExpression
                                              :GammaDistributionExpression
                                            )
                              ] ;
                  rdfs:range xsd:double ;
                  rdfs:comment "Defines the alpha parameter of a probability distribution, which is the shape parameter that determines the skewness of the distribution"@en ;
                  rdfs:label "has alfa parameter"@en ,
                             "tiene el parámetro alfa"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasAuthor
:hasAuthor rdf:type owl:DatatypeProperty ;
           rdfs:domain :Model ;
           rdfs:range xsd:string ;
           rdfs:comment "Defines the author of a model. This can be useful for defining the author of a model, for example, to give credit to the creator of the model or to provide contact information for questions about the model."@en ;
           rdfs:label "has author"@en ,
                      "tiene el autor"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasAverageParameter
:hasAverageParameter rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf :hasProbabilityDistributionParameter ;
                     rdfs:domain :ProbabilityDistributionExpression ;
                     rdfs:range xsd:double ;
                     rdfs:comment "Defines the average parameter of a probability distribution, which is the mean of the distribution. This is useful for probability distributions which are defined by their mean and another parameter, such as the normal distribution (defined by its mean and standard deviation) or the Poisson distribution (defined by its mean, which is also its lambda parameter)."@en ;
                     rdfs:label "has average parameter"@en ,
                                "tiene el parámetro promedio"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasBetaParameter
:hasBetaParameter rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf :hasProbabilityDistributionParameter ;
                  rdfs:domain :BetaDistributionExpression ;
                  rdfs:range xsd:double ;
                  rdfs:comment "Defines the beta parameter of a beta distribution, which is the shape parameter that determines the skewness of the distribution"@en ;
                  rdfs:label "has beta parameter"@en ,
                             "tiene el parámetro beta"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasCalculationMethod
:hasCalculationMethod rdf:type owl:DatatypeProperty ;
                      rdfs:domain :QoLDataItemType ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Defines the method used to calculate a quality of life data item, for example, a utility or disutility. This can be useful for defining the method used to calculate a utility or disutility from a questionnaire, for example."@en ;
                      rdfs:label "has calculation method"@en ,
                                 "tiene el método de cálculo"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasDescription
:hasDescription rdf:type owl:DatatypeProperty ;
                rdfs:domain :Describable ;
                rdfs:range xsd:string ;
                rdfs:comment "Description of the model item"@en ;
                rdfs:label "has description"@en ,
                           "tiene la descripción"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasDiscountForCosts
:hasDiscountForCosts rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Experiment ;
                     rdfs:range xsd:double ;
                     rdfs:comment "Defines the discount rate for costs in the experiment."@en ;
                     rdfs:label "has discount for costs"@en ,
                                "tiene el descuento para costos"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasDiscountForEffects
:hasDiscountForEffects rdf:type owl:DatatypeProperty ;
                       rdfs:domain :Experiment ;
                       rdfs:range xsd:double ;
                       rdfs:comment "Defines the discount rate for effects in the experiment."@en ;
                       rdfs:label "has discount for effects"@en ,
                                  "tiene el descuento para efectos"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasDisutilityCombinationMethod
:hasDisutilityCombinationMethod rdf:type owl:DatatypeProperty ;
                                rdfs:domain :Experiment ;
                                rdfs:range [ rdf:type rdfs:Datatype ;
                                             owl:oneOf [ rdf:type rdf:List ;
                                                         rdf:first "ADD" ;
                                                         rdf:rest [ rdf:type rdf:List ;
                                                                    rdf:first "MAX" ;
                                                                    rdf:rest rdf:nil
                                                                  ]
                                                       ]
                                           ] ;
                                rdfs:comment "Defines the method used to combine disutilities in the experiment. This is useful for calculating the combined disutility of multiple health conditions or interventions in a population. The most common methods are ADD (which assumes that the disutilities are additive) and MAX (which assumes that the disutility of the combination is equal to the maximum disutility among the combined conditions or interventions)."@en ;
                                rdfs:label "has disutility combination method"@en ,
                                           "tiene el método de combinación de disutilidades"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasExpectedValue
:hasExpectedValue rdf:type owl:DatatypeProperty ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( :DeterministicParameter
                                              :SecondOrderUncertaintyParameter
                                            )
                              ] ;
                  rdfs:range xsd:double ;
                  rdfs:comment "The expected value of a parameter with uncertainty. This is useful for deterministic parameters with uncertainty, which can be used in deterministic sensitivity analysis, and for second-order uncertainty parameters, which are used in two-level PSA."@en ;
                  rdfs:label "has expected value"@en ,
                             "tiene el valor esperado"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasExpressionValue
:hasExpressionValue rdf:type owl:DatatypeProperty ;
                    rdfs:domain :CalculatedParameter ;
                    rdfs:range xsd:string ;
                    rdfs:comment "The expression in a formal language to calculate the value of a calculated parameter. The expression must be written using the syntax of the expression language defined for that parameter (see property isExpressionLanguageOf)."@en ;
                    rdfs:label "has expression value"@en ,
                               "tiene el valor de expresión"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasGeographicalContext
:hasGeographicalContext rdf:type owl:DatatypeProperty ;
                        rdfs:domain [ rdf:type owl:Class ;
                                      owl:unionOf ( :Model
                                                    :Parameter
                                                    :Population
                                                  )
                                    ] ;
                        rdfs:range xsd:string ;
                        rdfs:comment "Defines the geographical context of a model, parameter or population. This can be useful for defining the scope of applicability of a model or parameter, for example."@en ;
                        rdfs:label "has geographical context"@en ,
                                   "tiene el contexto geográfico"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasHoursInterval
:hasHoursInterval rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Guideline ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Interval in which the indicated dose of drug should be given."@en ;
                  rdfs:label "has hours interval"@en ,
                             "tiene el intervalo de horas"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasLambdaParameter
:hasLambdaParameter rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf :hasProbabilityDistributionParameter ;
                    rdfs:domain [ rdf:type owl:Class ;
                                  owl:unionOf ( :ExponentialDistributionExpression
                                                :GammaDistributionExpression
                                                :PoissonDistributionExpression
                                              )
                                ] ;
                    rdfs:range xsd:double ;
                    rdfs:comment "Defines the lambda parameter of a probability distribution, which is the rate parameter in an exponential distribution, the shape parameter in a gamma distribution and the average number of events in a Poisson distribution"@en ;
                    rdfs:label "has lambda parameter"@en ,
                               "tiene el parámetro lambda"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasLowerLimitParameter
:hasLowerLimitParameter rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf :hasProbabilityDistributionParameter ;
                        rdfs:domain :UniformDistributionExpression ;
                        rdfs:range xsd:double ;
                        rdfs:comment "Defines the lower limit parameter of a uniform distribution"@en ;
                        rdfs:label "has lower limit parameter"@en ,
                                   "tiene el parámetro de límite inferior"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasMaxAge
:hasMaxAge rdf:type owl:DatatypeProperty ;
           rdfs:domain :Population ;
           rdfs:range xsd:double ;
           rdfs:comment "Defines the maximum age of a population"@en ;
           rdfs:label "has maximum age"@en ,
                      "tiene la edad máxima"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasMinAge
:hasMinAge rdf:type owl:DatatypeProperty ;
           rdfs:domain :Population ;
           rdfs:range xsd:double ;
           rdfs:comment "Defines the minimum age of a population"@en ;
           rdfs:label "has minimum age"@en ,
                      "tiene la edad mínima"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasNullProgression
:hasNullProgression rdf:type owl:DatatypeProperty ;
                    rdfs:domain :AlternativeCombinationRule ;
                    rdfs:range xsd:boolean ;
                    rdfs:comment "Indicates that an alternative rule combination defines an option for \"none of the above\""@en ;
                    rdfs:label "has null progression"@en ,
                               "tiene progresión nula"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasNumberOfPSARuns
:hasNumberOfPSARuns rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Experiment ;
                    rdfs:range xsd:integer ;
                    rdfs:comment "Defines the number of runs for the probabilistic sensitivity analysis (PSA) in the experiment"@en ;
                    rdfs:label "has number of PSA runs"@en ,
                               "tiene número de ejecuciones de PSA"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasNumberOfSimulatedIndividuals
:hasNumberOfSimulatedIndividuals rdf:type owl:DatatypeProperty ;
                                 rdfs:domain :Experiment ;
                                 rdfs:range xsd:integer ;
                                 rdfs:comment "Defines the number of simulated individuals in the experiment"@en ;
                                 rdfs:label "has number of simulated individuals"@en ,
                                            "tiene número de individuos simulados"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasOffsetParameter
:hasOffsetParameter rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf :hasProbabilityDistributionParameter ;
                    rdfs:domain :ProbabilityDistributionExpression ;
                    rdfs:range xsd:double ;
                    rdfs:comment "Defines the offset parameter of a probability distribution, which is a value that is added to the random variable defined by the distribution. This is useful for defining distributions that can only take values above or below a certain threshold (for example, an offset of 1 in a Poisson distribution would define a distribution that can only take values from 1 to infinite, instead of from 0 to infinite)."@en ;
                    rdfs:label "has offset parameter"@en ,
                               "tiene el parámetro de desplazamiento"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasProbabilityDistributionParameter
:hasProbabilityDistributionParameter rdf:type owl:DatatypeProperty ;
                                     rdfs:domain :ProbabilityDistributionExpression ;
                                     rdfs:range xsd:double ;
                                     rdfs:comment "Defines a parameter of a probability distribution. This is a general property which can be used for any parameter of any probability distribution, but more specific subproperties are provided for the most common parameters (average, variance, lambda, etc.)"@en ;
                                     rdfs:label "has probability distribution parameter"@en ,
                                                "tiene el parámetro de distribución de probabilidad"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasProbabilityParameter
:hasProbabilityParameter rdf:type owl:DatatypeProperty ;
                         rdfs:subPropertyOf :hasProbabilityDistributionParameter ;
                         rdfs:domain :BernoulliDistributionExpression ;
                         rdfs:range xsd:double ;
                         rdfs:comment "Defines the probability parameter of a Bernoulli distribution"@en ;
                         rdfs:label "has probability parameter"@en ,
                                    "tiene el parámetro de probabilidad"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasRange
:hasRange rdf:type owl:DatatypeProperty ;
          rdfs:domain :Guideline ;
          rdfs:range xsd:string ;
          rdfs:comment """Age range in which the drug will be delivered.

Examples: 
   0y-2y    => 0 years to 2 years
   3m-2y   => 3 months to 2 years""" .


###  https://w3id.org/ontologies-ULL/OSDi#hasRefTo
:hasRefTo rdf:type owl:DatatypeProperty ;
          rdfs:domain [ rdf:type owl:Class ;
                        owl:unionOf ( :DataItemType
                                      :Model
                                      :ModelItem
                                    )
                      ] ;
          rdfs:range xsd:string ;
          rdfs:comment "Reference to the corresponding item in an external ontology or database, if available"@en ;
          rdfs:label "has reference to"@en ,
                     "tiene la referencia a"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasRefToDO
:hasRefToDO rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf :hasRefTo ;
            rdfs:domain :Disease ;
            rdfs:range xsd:string ;
            rdfs:comment "Reference to the corresponding item in DO, if available"@en ;
            rdfs:label "has reference to DO"@en ,
                       "tiene la referencia a DO"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasRefToGARD
:hasRefToGARD rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf :hasRefTo ;
              rdfs:domain :RareDisease ;
              rdfs:range xsd:string ;
              rdfs:comment "Reference to the corresponding item in GARD, if available"@en ;
              rdfs:label "has reference to GARD"@en ,
                         "tiene la referencia a GARD"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasRefToICD
:hasRefToICD rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf :hasRefTo ;
             rdfs:domain [ rdf:type owl:Class ;
                           owl:unionOf ( :ClinicalProgressionElement
                                         :Disease
                                       )
                         ] ;
             rdfs:range xsd:string ;
             rdfs:comment "Reference to the corresponding item in ICD, if available"@en ;
             rdfs:label "has reference to ICD"@en ,
                        "tiene la referencia a ICD"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasRefToOMIM
:hasRefToOMIM rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf :hasRefTo ;
              rdfs:domain :Disease ;
              rdfs:range xsd:string ;
              rdfs:comment "Reference to the corresponding item in OMIM, if available"@en ;
              rdfs:label "has reference to OMIM"@en ,
                         "tiene la referencia a OMIM"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasRefToORDO
:hasRefToORDO rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf :hasRefTo ;
              rdfs:domain :RareDisease ;
              rdfs:range xsd:string ;
              rdfs:comment "Reference to the corresponding item in ORDO, if available"@en ;
              rdfs:label "has reference to ORDO"@en ,
                         "tiene la referencia a ORDO"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasRefToSNOMED
:hasRefToSNOMED rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf :hasRefTo ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( :Attribute
                                            :Disease
                                          )
                            ] ;
                rdfs:range xsd:string ;
                rdfs:comment "Reference to the corresponding item in SNOMED CT, if available"@en ;
                rdfs:label "has reference to SNOMED"@en ,
                           "tiene la referencia a SNOMED"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasRefToSTATO
:hasRefToSTATO rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf :hasRefTo ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( :DataItemType
                                           :ProbabilityDistributionExpression
                                         )
                           ] ;
               rdfs:range xsd:string ;
               rdfs:comment "Reference to the corresponding item in STATO, if available"@en ;
               rdfs:label "has reference to STATO"@en ,
                          "tiene la referencia a STATO"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasRefToWikidata
:hasRefToWikidata rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf :hasRefTo ;
                  rdfs:domain :Currency ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Reference to the corresponding item in Wikidata, if available"@en ;
                  rdfs:label "has reference to Wikidata"@en ,
                             "tiene la referencia a Wikidata"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasScaleParameter
:hasScaleParameter rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf :hasProbabilityDistributionParameter ;
                   rdfs:domain :ProbabilityDistributionExpression ;
                   rdfs:range xsd:double ;
                   rdfs:comment "Defines the scale parameter of a probability distribution"@en ;
                   rdfs:label "has scale parameter"@en ,
                              "tiene el parámetro de escala"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasSize
:hasSize rdf:type owl:DatatypeProperty ;
         rdfs:domain :Population ;
         rdfs:range xsd:integer ;
         rdfs:comment "Number of individuals in the population"@en ;
         rdfs:label "has size"@en ,
                    "tiene el tamaño"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasSource
:hasSource rdf:type owl:DatatypeProperty ;
           rdfs:domain :Parameter ;
           rdfs:range xsd:string ;
           rdfs:comment "Source of the parameter value, e.g., a bibliographic reference, name of a dataset, name of an expert..."@en ;
           rdfs:label "has source"@en ,
                      "tiene la fuente"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasStandardDeviationParameter
:hasStandardDeviationParameter rdf:type owl:DatatypeProperty ;
                               rdfs:subPropertyOf :hasProbabilityDistributionParameter ;
                               rdfs:domain :ProbabilityDistributionExpression ;
                               rdfs:range xsd:double ;
                               rdfs:comment "Defines the standard deviation parameter of a probability distribution"@en ;
                               rdfs:label "has standard deviation parameter"@en ,
                                          "tiene el parámetro de desviación estándar"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasTimeHorizon
:hasTimeHorizon rdf:type owl:DatatypeProperty ;
                rdfs:domain :Experiment ;
                rdfs:range xsd:double ;
                rdfs:comment "Defines the time horizon (in years) applied to a simulation"@en ;
                rdfs:label "has time horizon"@en ,
                           "tiene horizonte temporal"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasUnit
:hasUnit rdf:type owl:DatatypeProperty ;
         rdfs:domain :MeasuredDataItemType ;
         rdfs:range xsd:string ;
         rdfs:comment "Unit of measurement of a data item type, e.g., \"years\", \"kg\", \"number of cases\"..."@en ;
         rdfs:label "has unit"@en ,
                    "tiene la unidad"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasUpperLimitParameter
:hasUpperLimitParameter rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf :hasProbabilityDistributionParameter ;
                        rdfs:domain :UniformDistributionExpression ;
                        rdfs:range xsd:double ;
                        rdfs:comment "Defines the upper limit parameter of a uniform distribution"@en ;
                        rdfs:label "has upper limit parameter"@en ,
                                   "tiene el parámetro de límite superior"@es .


###  https://w3id.org/ontologies-ULL/OSDi#hasYear
:hasYear rdf:type owl:DatatypeProperty ;
         rdfs:domain [ rdf:type owl:Class ;
                       owl:unionOf ( :Experiment
                                     :Parameter
                                     :Population
                                   )
                     ] ;
         rdfs:range xsd:short ;
         rdfs:comment "Year in which the cost data is collected" ;
         rdfs:label "has year"@en ,
                    "tiene el año"@es .


###  https://w3id.org/ontologies-ULL/OSDi#isAssessedIntervention
:isAssessedIntervention rdf:type owl:DatatypeProperty ;
                        rdfs:domain :Intervention ;
                        rdfs:range xsd:boolean ;
                        rdfs:comment "Indicates whether an intervention is being assessed or it is a comparator"@en ;
                        rdfs:label "es una intervención evaluada"@es ,
                                   "is assessed intervention"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isDisutility
:isDisutility rdf:type owl:DatatypeProperty ;
              rdfs:domain :Utility ;
              rdfs:range xsd:boolean ;
              rdfs:comment "Indicates whether a utility parameter represents a disutility or a utility"@en ;
              rdfs:label "es una desutilidad"@es ,
                         "is disutility"@en .


###  https://w3id.org/ontologies-ULL/OSDi#isTrueEpidemiologicalParameterEstimate
:isTrueEpidemiologicalParameterEstimate rdf:type owl:DatatypeProperty ;
                                        rdfs:domain :EpidemiologicalParameter ;
                                        rdfs:range xsd:boolean ;
                                        rdfs:comment "Indicates whether an epidemiological parameter is a true estimate of the parameter or an estimation with known biases"@en ;
                                        rdfs:label "es una estimación verdadera de un parámetro epidemiológico"@es ,
                                                   "is true epidemiological parameter estimate"@en .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
<http://www.w3.org/2004/02/skos/core#ConceptScheme> rdf:type owl:Class .


###  https://w3id.org/ontologies-ULL/OSDi#AcuteManifestation
:AcuteManifestation rdf:type owl:Class ;
                    rdfs:subClassOf :Manifestation ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :hasFrequency ;
                                      owl:allValuesFrom :Parameter
                                    ] ;
                    owl:disjointWith :ClinicalProgressionWithInitialProportion ;
                    rdfs:comment "Sudden or rapid appearance of clinical signs or symtoms, in general with a short and intense course"@en ;
                    rdfs:label "Acute manifestation"@en ,
                               "Manifestación aguda"@es .


###  https://w3id.org/ontologies-ULL/OSDi#AgentBasedModel
:AgentBasedModel rdf:type owl:Class ;
                 rdfs:subClassOf :Model ;
                 rdfs:comment "An model based on using multiple agents"@en ;
                 rdfs:label "Agent based model"@en ,
                            "Modelo basado en agentes"@es .


###  https://w3id.org/ontologies-ULL/OSDi#AlternativeCombinationRule
:AlternativeCombinationRule rdf:type owl:Class ;
                            rdfs:subClassOf :ProgressionCombinationRule ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasNullProgression ;
                                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onDataRange xsd:boolean
                                            ] ;
                            rdfs:comment "A set of disease progressions which are treated as mutually exclusive alternatives, e.g., a mild and a severe development of certain disease" ;
                            rdfs:label "Alternative disease progression set"@en ,
                                       "Conjunto de progresiones de enfermedad alternativas"@es .


###  https://w3id.org/ontologies-ULL/OSDi#Attribute
:Attribute rdf:type owl:Class ;
           rdfs:subClassOf :ModelItem ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasAttributeValue ;
                             owl:allValuesFrom :Parameter
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :isAffectedBy ;
                             owl:allValuesFrom :Effect
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasRefToSNOMED ;
                             owl:allValuesFrom xsd:string
                           ] ;
           owl:disjointWith :ModelItemDefiningDiseaseProgression ,
                            :ModelItemWithCost ,
                            :ModelItemWithDetection ,
                            :ModelItemWithEffect ,
                            :ModelItemWithFollowUp ,
                            :ModelItemWithRiskCharacterization ,
                            :ModelItemWithTemporalConstraints ,
                            :ModelItemWithTreatment ,
                            :ModelItemWithUtility ;
           rdfs:comment "Clinical parameters that define the state of a patient and whose value may modify the evolution of the Disease and/or specific manifestations"@en ;
           rdfs:label "Atributo"@es ,
                      "Attribute"@en .


###  https://w3id.org/ontologies-ULL/OSDi#AttributeValueParameter
:AttributeValueParameter rdf:type owl:Class ;
                         owl:equivalentClass [ owl:intersectionOf ( :Parameter
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty :isValueOfAttribute ;
                                                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                      owl:onClass :Attribute
                                                                    ]
                                                                  ) ;
                                               rdf:type owl:Class
                                             ] ;
                         rdfs:subClassOf :Parameter ;
                         rdfs:comment "A parameter that represents the value of an attribute"@en ;
                         rdfs:label "Attribute Value Parameter"@en ,
                                    "Parámetro de valor de atributo"@es .


###  https://w3id.org/ontologies-ULL/OSDi#BernoulliDistributionExpression
:BernoulliDistributionExpression rdf:type owl:Class ;
                                 rdfs:subClassOf :ProbabilityDistributionExpression ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :hasRefToSTATO ;
                                                   owl:hasValue "http://purl.obolibrary.org/obo/STATO_0000262"
                                                 ] ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :hasProbabilityParameter ;
                                                   owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                   owl:onDataRange xsd:double
                                                 ] ;
                                 rdfs:comment "A discrete (0-1) probability distribution with just one parameter (the probability of an event)"@en ;
                                 rdfs:label "Expresión para distribución de probabilidad de Bernoulli"@es ,
                                            "Expression for a Bernoulli probability distribution"@en .


###  https://w3id.org/ontologies-ULL/OSDi#BetaDistributionExpression
:BetaDistributionExpression rdf:type owl:Class ;
                            rdfs:subClassOf :ProbabilityDistributionExpression ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasRefToSTATO ;
                                              owl:hasValue "http://purl.obolibrary.org/obo/STATO_0000177"
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasAlfaParameter ;
                                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onDataRange xsd:double
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasBetaParameter ;
                                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onDataRange xsd:double
                                            ] ;
                            rdfs:comment "Continuous probability distributions defined on the interval [0, 1] parametrized by two positive shape parameters, alfa and beta, generally estimated from the number of 'cases' and 'no cases' from an event"@en ;
                            rdfs:label "Expresión para distribución de probabilidad Beta"@es ,
                                       "Expression for a Beta probability distribution"@en .


###  https://w3id.org/ontologies-ULL/OSDi#CalculatedParameter
:CalculatedParameter rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( :Parameter
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty :dependsOn ;
                                                                  owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                                                  owl:onClass [ rdf:type owl:Class ;
                                                                                owl:unionOf ( :Attribute
                                                                                              :Parameter
                                                                                            )
                                                                              ]
                                                                ]
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty :hasExpressionLanguage ;
                                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                  owl:onClass :ExpressionLanguage
                                                                ]
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty :hasExpressionValue ;
                                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                  owl:onDataRange xsd:string
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:subClassOf :ParameterNature ;
                     rdfs:comment "Parameter which value is computed using an expression, generally dependent on other parameters"@en ;
                     rdfs:label "Calculated Parameter"@en ,
                                "Parámetro calculado"@es .


###  https://w3id.org/ontologies-ULL/OSDi#ChronicManifestation
:ChronicManifestation rdf:type owl:Class ;
                      rdfs:subClassOf :Manifestation ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :hasInitialProportion ;
                                        owl:allValuesFrom [ owl:intersectionOf ( :Parameter
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty :isParameterOf ;
                                                                                   owl:someValuesFrom :Population
                                                                                 ]
                                                                               ) ;
                                                            rdf:type owl:Class
                                                          ]
                                      ] ;
                      rdfs:comment "Long-lasting or frequently recurring set of signs and symptoms"@en ;
                      rdfs:label "Chronic manifestation"@en ,
                                 "Manifestación crónica"@es .


###  https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement
:ClinicalProgressionElement rdf:type owl:Class ;
                            rdfs:subClassOf :DiseaseProgressionElement ,
                                            :HealthCondition ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasDuration ;
                                              owl:allValuesFrom :Parameter
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasEndAge ;
                                              owl:allValuesFrom :Parameter
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasOnsetAge ;
                                              owl:allValuesFrom :Parameter
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasRiskCharacterization ;
                                              owl:allValuesFrom [ rdf:type owl:Class ;
                                                                  owl:unionOf ( :Parameter
                                                                                :Pathway
                                                                              )
                                                                ]
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasStrategy ;
                                              owl:allValuesFrom [ rdf:type owl:Class ;
                                                                  owl:unionOf ( :FollowUpStrategy
                                                                                :LineOfTherapy
                                                                              )
                                                                ]
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasSubProgression ;
                                              owl:allValuesFrom :ClinicalProgressionElement
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :supersedesClinicalProgression ;
                                              owl:allValuesFrom :ClinicalProgressionElement
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasRefToICD ;
                                              owl:allValuesFrom xsd:string
                                            ] ;
                            rdfs:comment "Any way in which a disease can progress: manifestations, symptoms, stages..."@en ;
                            rdfs:label "Disease progression"@en ,
                                       "Progresión de una enfermedad"@es .


###  https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionWithInitialProportion
:ClinicalProgressionWithInitialProportion rdf:type owl:Class ;
                                          owl:equivalentClass [ owl:intersectionOf ( :ClinicalProgressionElement
                                                                                     [ rdf:type owl:Restriction ;
                                                                                       owl:onProperty :hasInitialProportion ;
                                                                                       owl:someValuesFrom [ owl:intersectionOf ( :Parameter
                                                                                                                                 [ rdf:type owl:Restriction ;
                                                                                                                                   owl:onProperty :isParameterOf ;
                                                                                                                                   owl:someValuesFrom :Population
                                                                                                                                 ]
                                                                                                                               ) ;
                                                                                                            rdf:type owl:Class
                                                                                                          ]
                                                                                     ]
                                                                                   ) ;
                                                                rdf:type owl:Class
                                                              ] ;
                                          rdfs:subClassOf :ClinicalProgressionElement ;
                                          rdfs:comment "A clinical progression element that is present in an initial proportion in a population"@en ;
                                          rdfs:label "Clinical progression with initial proportion"@en ,
                                                     "Progresión clínica con proporción inicial"@es .


###  https://w3id.org/ontologies-ULL/OSDi#CoexistentCombinationRule
:CoexistentCombinationRule rdf:type owl:Class ;
                           rdfs:subClassOf :ProgressionCombinationRule ;
                           rdfs:comment "A set of disease progressions which can coexist at the same time, e.g. seizures and skin problems." ;
                           rdfs:label "Coexistent disease progression set"@en ,
                                      "Conjunto de progresiones de enfermedad coexistentes"@es .


###  https://w3id.org/ontologies-ULL/OSDi#Cost
:Cost rdf:type owl:Class ;
      owl:equivalentClass [ owl:intersectionOf ( :YearDependantParameter
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :hasDataItemType ;
                                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                   owl:onClass :Currency
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] ;
      rdfs:subClassOf :YearDependantParameter ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :hasCategory ;
                        owl:allValuesFrom <http://www.w3.org/2004/02/skos/core#Concept>
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :appliesOneTime ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:boolean
                      ] ;
      rdfs:comment "The cost of any component of the model (intervention, treatment, disease progression...)"@en ;
      rdfs:label "Cost"@en ,
                 "Coste"@es .


###  https://w3id.org/ontologies-ULL/OSDi#Currency
:Currency rdf:type owl:Class ;
          rdfs:subClassOf :MeasuredDataItemType ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasRefToWikidata ;
                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ;
          rdfs:comment "Data type to express costs"@en ;
          rdfs:label "Currency"@en ,
                     "Moneda"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DataItemType
:DataItemType rdf:type owl:Class ;
              rdfs:subClassOf :Describable ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasRefToSTATO ;
                                owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ;
              rdfs:comment "The type to define the nature of a data item, either its statistic nature (probability, relative risk...) or some characteristic (currency, utility...)"@en ;
              rdfs:label "Data item type"@en ,
                         "Tipo del elemento de datos"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DecisionTreeModel
:DecisionTreeModel rdf:type owl:Class ;
                   rdfs:subClassOf :Model ;
                   rdfs:comment "A model based on a decision tree"@en ;
                   rdfs:label "Decision tree model"@en ,
                              "Modelo de árbol de decisión"@es .


###  https://w3id.org/ontologies-ULL/OSDi#Describable
:Describable rdf:type owl:Class ;
             owl:equivalentClass [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasDescription ;
                                   owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                   owl:onDataRange xsd:string
                                 ] ;
             rdfs:comment "Any concept that can be described with a text"@en ;
             rdfs:label "Describable"@en ,
                        "Describible"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DetectionIntervention
:DetectionIntervention rdf:type owl:Class ;
                       owl:equivalentClass [ rdf:type owl:Class ;
                                             owl:unionOf ( :DiagnosisIntervention
                                                           :ScreeningIntervention
                                                         )
                                           ] ;
                       rdfs:subClassOf :Intervention ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :detects ;
                                         owl:allValuesFrom :Disease
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :hasSensitivity ;
                                         owl:allValuesFrom [ owl:intersectionOf ( :Parameter
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty :hasDataItemType ;
                                                                                    owl:hasValue :DI_Sensitivity
                                                                                  ]
                                                                                ) ;
                                                             rdf:type owl:Class
                                                           ]
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :hasSpecificity ;
                                         owl:allValuesFrom [ owl:intersectionOf ( :Parameter
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty :hasDataItemType ;
                                                                                    owl:hasValue :DI_Specificity
                                                                                  ]
                                                                                ) ;
                                                             rdf:type owl:Class
                                                           ]
                                       ] ;
                       owl:disjointUnionOf ( :DiagnosisIntervention
                                             :ScreeningIntervention
                                           ) ;
                       rdfs:comment "An intervention intended to detect the presence of a disease or condition in a person"@en ;
                       rdfs:label "Detection intervention"@en ,
                                  "Intervención de detección"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DetectionStrategy
:DetectionStrategy rdf:type owl:Class ;
                   rdfs:subClassOf :Strategy ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :detects ;
                                     owl:allValuesFrom :Disease
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasSensitivity ;
                                     owl:allValuesFrom [ owl:intersectionOf ( :Parameter
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :hasDataItemType ;
                                                                                owl:hasValue :DI_Sensitivity
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ]
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasSpecificity ;
                                     owl:allValuesFrom [ owl:intersectionOf ( :Parameter
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :hasDataItemType ;
                                                                                owl:hasValue :DI_Specificity
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ]
                                   ] ;
                   rdfs:comment "A strategy related to the detection of a disease"@es ;
                   rdfs:label "Detection strategy"@en ,
                              "Estrategia de detección"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DeterministicParameter
:DeterministicParameter rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( :Parameter
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :hasUncertaintyCharacterization ;
                                                                     owl:maxQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                                                     owl:onClass [ rdf:type owl:Class ;
                                                                                   owl:unionOf ( :Parameter
                                                                                                 :ProbabilityDistributionExpression
                                                                                               )
                                                                                 ]
                                                                   ]
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :hasExpectedValue ;
                                                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                     owl:onDataRange xsd:double
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf :ParameterNature ;
                        rdfs:comment "Parameter with a fixed (no-uncertainty) value"@en ;
                        rdfs:label "Deterministic parameter"@en ,
                                   "Parámetro determinista"@es .


###  https://w3id.org/ontologies-ULL/OSDi#Development
:Development rdf:type owl:Class ;
             rdfs:subClassOf :ClinicalProgressionElement ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasInitialProportion ;
                               owl:allValuesFrom [ owl:intersectionOf ( :Parameter
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty :isParameterOf ;
                                                                          owl:someValuesFrom :Population
                                                                        ]
                                                                      ) ;
                                                   rdf:type owl:Class
                                                 ]
                             ] ;
             rdfs:comment "Certain progression of a Disease that comprises a specific set of manifestations or a set of pathways to such manifestations"@en ;
             rdfs:label "Desarrollo"@es ,
                        "Development"@en .


###  https://w3id.org/ontologies-ULL/OSDi#DiagnosisIntervention
:DiagnosisIntervention rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( :DetectionIntervention
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :hasCategory ;
                                                                    owl:hasValue :DiagnosisCat
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] ;
                       rdfs:subClassOf :DetectionIntervention ;
                       owl:disjointWith :ScreeningIntervention ;
                       rdfs:comment "An intervention intended to establish the presence/absence of certain disease or condition"@en ;
                       rdfs:label "Diagnosis intervention"@en ,
                                  "Intervención diagnóstica"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DiagnosisStrategy
:DiagnosisStrategy rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( :DetectionStrategy
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty :hasCategory ;
                                                                owl:hasValue :DiagnosisCat
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   rdfs:subClassOf :DetectionStrategy ;
                   rdfs:comment "A strategy related to the diagnosis of a disease"@es ;
                   rdfs:label "Diagnosis strategy"@en ,
                              "Estrategia de diagnóstico"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DiscreteEventSimulationModel
:DiscreteEventSimulationModel rdf:type owl:Class ;
                              rdfs:subClassOf :Model ;
                              rdfs:comment "A model based on discrete events and entities"@en ;
                              rdfs:label "Discrete-event simulation model"@en ,
                                         "Modelo de simulación de eventos discretos"@es .


###  https://w3id.org/ontologies-ULL/OSDi#Disease
:Disease rdf:type owl:Class ;
         rdfs:subClassOf :HealthCondition ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasEpidemiologicalParameter ;
                           owl:allValuesFrom [ owl:intersectionOf ( :EpidemiologicalParameter
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty :isParameterOf ;
                                                                      owl:someValuesFrom :Population
                                                                    ]
                                                                  ) ;
                                               rdf:type owl:Class
                                             ]
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasIntervention ;
                           owl:allValuesFrom :Intervention
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasProgressionElement ;
                           owl:allValuesFrom :DiseaseProgressionElement
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasRiskCharacterization ;
                           owl:allValuesFrom [ rdf:type owl:Class ;
                                               owl:unionOf ( :Parameter
                                                             :Pathway
                                                           )
                                             ]
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :usesAttributeValue ;
                           owl:allValuesFrom :Parameter
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasRefToDO ;
                           owl:allValuesFrom xsd:string
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasRefToICD ;
                           owl:allValuesFrom xsd:string
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasRefToOMIM ;
                           owl:allValuesFrom xsd:string
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasRefToSNOMED ;
                           owl:allValuesFrom xsd:string
                         ] ;
         rdfs:comment "Any type of disease or health condition that a person may suffer. Since diseases may have or not costs, utilities... all of these properties has been explicitly defined with cardinality 'min 0' as an hint for the ontology users"@en ;
         rdfs:label "Disease"@en ,
                    "Enfermedad"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DiseaseProgressionElement
:DiseaseProgressionElement rdf:type owl:Class ;
                           rdfs:subClassOf :ModelItem ;
                           rdfs:comment "An element characterizing the progression of a disease"@en ;
                           rdfs:label "Disease progression element"@en ,
                                      "Elemento de progresión de la enfermedad"@es .


###  https://w3id.org/ontologies-ULL/OSDi#Effect
:Effect rdf:type owl:Class ;
        rdfs:subClassOf :ModelItem ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :affects ;
                          owl:allValuesFrom [ rdf:type owl:Class ;
                                              owl:unionOf ( :Attribute
                                                            :Parameter
                                                          )
                                            ]
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasEffectMagnitude ;
                          owl:allValuesFrom :Parameter
                        ] ;
        rdfs:comment "An effect of a treatment or intervention"@en ;
        rdfs:label "Efecto"@es ,
                   "Effect"@en .


###  https://w3id.org/ontologies-ULL/OSDi#EpidemiologicalParameter
:EpidemiologicalParameter rdf:type owl:Class ;
                          owl:equivalentClass [ owl:intersectionOf ( :Parameter
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty :isTrueEpidemiologicalParameterEstimate ;
                                                                       owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                       owl:onDataRange xsd:boolean
                                                                     ]
                                                                   ) ;
                                                rdf:type owl:Class
                                              ] ;
                          rdfs:subClassOf :Parameter ;
                          rdfs:comment "A parameter related to the epidemiology (prevalence, incidence...) of a disease or condition"@en ;
                          rdfs:label "Epidemiological parameter"@en ,
                                     "Parámetro epidemiológico"@es .


###  https://w3id.org/ontologies-ULL/OSDi#Experiment
:Experiment rdf:type owl:Class ;
            rdfs:subClassOf :Describable ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :usesModel ;
                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass :Model
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasDisutilityCombinationMethod ;
                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onDataRange [ rdf:type rdfs:Datatype ;
                                                owl:oneOf [ rdf:type rdf:List ;
                                                            rdf:first "ADD" ;
                                                            rdf:rest [ rdf:type rdf:List ;
                                                                       rdf:first "MAX" ;
                                                                       rdf:rest rdf:nil
                                                                     ]
                                                          ]
                                              ]
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasYear ;
                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onDataRange xsd:short
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasDiscountForCosts ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onDataRange xsd:double
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasDiscountForEffects ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onDataRange xsd:double
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasTimeHorizon ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onDataRange xsd:double
                            ] ;
            rdfs:comment "An HTA experiment that uses a model, some input parameters and obtains results"@en ;
            rdfs:label "Experiment"@en ,
                       "Experimento"@es .


###  https://w3id.org/ontologies-ULL/OSDi#ExponentialDistributionExpression
:ExponentialDistributionExpression rdf:type owl:Class ;
                                   rdfs:subClassOf :ProbabilityDistributionExpression ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :hasRefToSTATO ;
                                                     owl:hasValue "http://purl.obolibrary.org/obo/STATO_0000160"
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :hasLambdaParameter ;
                                                     owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                     owl:onDataRange xsd:double
                                                   ] ;
                                   rdfs:comment "Continuous probability distribution that describes the time between events in a Poisson process, i.e. a process in which events occur continuously and independently at a constant average rate"@en ;
                                   rdfs:label "Expresión para distribución de probabilidad Exponencial"@es ,
                                              "Expression for an Expnential probability distribution"@en .


###  https://w3id.org/ontologies-ULL/OSDi#ExpressionLanguage
:ExpressionLanguage rdf:type owl:Class ;
                    owl:equivalentClass [ rdf:type owl:Class ;
                                          owl:oneOf ( :Exp_Excel
                                                      :Exp_JEXL
                                                      :Exp_Java
                                                      :Exp_Javaluator
                                                    )
                                        ] ;
                    rdfs:subClassOf :Describable ;
                    rdfs:comment "Language used to define an expression in a string. Generally used to compute something from other items of the model. Only the predefined languages are allowed, but future versions of the ontology may include more."@en ;
                    rdfs:label "Expression language"@en ,
                               "Lenguaje de expresión"@es .


###  https://w3id.org/ontologies-ULL/OSDi#FirstOrderUncertaintyParameter
:FirstOrderUncertaintyParameter rdf:type owl:Class ;
                                owl:equivalentClass [ owl:intersectionOf ( :Parameter
                                                                           [ rdf:type owl:Restriction ;
                                                                             owl:onProperty :hasUncertaintyCharacterization ;
                                                                             owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                  owl:unionOf ( :Parameter
                                                                                                                :ProbabilityDistributionExpression
                                                                                                              )
                                                                                                ]
                                                                           ]
                                                                           [ rdf:type owl:Restriction ;
                                                                             owl:onProperty :hasExpectedValue ;
                                                                             owl:maxQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                                                             owl:onDataRange xsd:double
                                                                           ]
                                                                         ) ;
                                                      rdf:type owl:Class
                                                    ] ;
                                rdfs:subClassOf :ParameterNature ;
                                rdfs:comment "Parameter which value has first-order uncertainty, i.e., the value for each individual is not fixed"@en ;
                                rdfs:label "First-order uncertainty parameter"@en ,
                                           "Parámetro con incertidumbre de primer orden"@es .


###  https://w3id.org/ontologies-ULL/OSDi#FollowUpStrategy
:FollowUpStrategy rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( :Strategy
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty :hasCategory ;
                                                               owl:hasValue :FollowUpCat
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf :Strategy ;
                  rdfs:comment "A strategy related to the follow-up of a disease or condition"@es ;
                  rdfs:label "Estrategia de seguimiento"@es ,
                             "Follow-up strategy"@en .


###  https://w3id.org/ontologies-ULL/OSDi#GammaDistributionExpression
:GammaDistributionExpression rdf:type owl:Class ;
                             rdfs:subClassOf :ProbabilityDistributionExpression ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :hasRefToSTATO ;
                                               owl:hasValue "http://purl.obolibrary.org/obo/STATO_0000268"
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :hasAlfaParameter ;
                                               owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onDataRange xsd:double
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :hasLambdaParameter ;
                                               owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onDataRange xsd:double
                                             ] ;
                             rdfs:comment "Continuous distribution of probability generally used to model costs, characterized by two parameters: alpha (shape) and lamba (scale)"@en ;
                             rdfs:label "Expresión para distribución de probabilidad Gamma"@es ,
                                        "Expression for a Gamma probability distribution"@en .


###  https://w3id.org/ontologies-ULL/OSDi#Group
:Group rdf:type owl:Class ;
       owl:equivalentClass [ owl:intersectionOf ( :ModelItem
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :hasGroupItem ;
                                                    owl:someValuesFrom :GroupableModelItem
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ;
       rdfs:subClassOf :ModelItem ;
       rdfs:comment "A group of model items. Useful to categorize or 'putting together' manifestations (e.g. all the eye-related manifestations of diabetes) or other model items"@en ;
       rdfs:label "Group"@en ,
                  "Grupo"@es .


###  https://w3id.org/ontologies-ULL/OSDi#GroupableModelItem
:GroupableModelItem rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( :ModelItem
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty :belongsToGroup ;
                                                                 owl:someValuesFrom :Group
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf :ModelItem ;
                    rdfs:comment "A model item that can be put in a group"@en ;
                    rdfs:label "Elemento del modelo agrupable"@es ,
                               "Groupable model item"@en .


###  https://w3id.org/ontologies-ULL/OSDi#GroupableModelItemWithProportion
:GroupableModelItemWithProportion rdf:type owl:Class ;
                                  owl:equivalentClass [ owl:intersectionOf ( :GroupableModelItem
                                                                             [ rdf:type owl:Restriction ;
                                                                               owl:onProperty :hasProportionWithinGroup ;
                                                                               owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                                                               owl:onClass :Parameter
                                                                             ]
                                                                           ) ;
                                                        rdf:type owl:Class
                                                      ] ;
                                  rdfs:subClassOf :GroupableModelItem ;
                                  rdfs:comment "A model item that can be put in a group"@en ;
                                  rdfs:label "Elemento del modelo agrupable"@es ,
                                             "Groupable model item"@en .


###  https://w3id.org/ontologies-ULL/OSDi#Guideline
:Guideline rdf:type owl:Class ;
           rdfs:subClassOf :ModelItem ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasGuideline ;
                             owl:someValuesFrom :Guideline
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasConditionExpression ;
                             owl:allValuesFrom :Parameter
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasDose ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :Parameter
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasFrequency ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :Parameter
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasRange ;
                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onDataRange xsd:string
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasHoursInterval ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onDataRange xsd:string
                           ] ;
           owl:disjointWith :ModelItemWithCost ,
                            :ModelItemWithUtility ;
           rdfs:comment "The way a treatment, drug, test... is applied. It defines a period of time (range), dose, frequency, etc." ;
           rdfs:label "Guideline"@en ,
                      "Pauta"@es .


###  https://w3id.org/ontologies-ULL/OSDi#HealthCondition
:HealthCondition rdf:type owl:Class ;
                 rdfs:subClassOf :ModelItem ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasCost ;
                                   owl:allValuesFrom :Cost
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasEffect ;
                                   owl:allValuesFrom :Effect
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasStrategy ;
                                   owl:allValuesFrom :Strategy
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasUtility ;
                                   owl:allValuesFrom :Utility
                                 ] ;
                 rdfs:comment "Any disease, symptom or clinical sign that affects the health of an individual"@en ;
                 rdfs:label "Condición de salud"@es ,
                            "Health condition"@en .


###  https://w3id.org/ontologies-ULL/OSDi#HealthTechnology
:HealthTechnology rdf:type owl:Class ;
                  rdfs:subClassOf :ResourceUsageItem ;
                  rdfs:comment "Any treatment, drug, test... that may be applied to a patient. In the context of this ontology, this class and its subclasses define resource usage to compute costs and must not be confused with the 'interventions'"@en ;
                  rdfs:label "Health technology"@en ,
                             "Tecnología sanitaria"@es .


###  https://w3id.org/ontologies-ULL/OSDi#IncreasedMortalityRateEffect
:IncreasedMortalityRateEffect rdf:type owl:Class ;
                              rdfs:subClassOf [ owl:intersectionOf ( :Effect
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty :affects ;
                                                                       owl:hasValue :Attribute_LifeExpectancy
                                                                     ]
                                                                   ) ;
                                                rdf:type owl:Class
                                              ] ;
                              rdfs:comment "An increment on the mortality rate of an individual or population."@en ;
                              rdfs:label "Efecto de incremento en la tasa de mortalidad"@es ,
                                         "Incresed of mortality rate effect"@en .


###  https://w3id.org/ontologies-ULL/OSDi#InfectiousDisease
:InfectiousDisease rdf:type owl:Class ;
                   rdfs:subClassOf :Disease ;
                   owl:disjointWith :InheritedDisease ;
                   rdfs:comment "A disease that is transmitted from one person to another through various means"@en ;
                   rdfs:label "Enfermedad infecciosa"@es ,
                              "Infectious disease"@en .


###  https://w3id.org/ontologies-ULL/OSDi#InheritedDisease
:InheritedDisease rdf:type owl:Class ;
                  rdfs:subClassOf :Disease ;
                  rdfs:comment "A disease that is passed down from parent to child through genes"@en ;
                  rdfs:label "Enfermedad hereditaria"@es ,
                             "Inherited disease"@en .


###  https://w3id.org/ontologies-ULL/OSDi#InstantDeathEffect
:InstantDeathEffect rdf:type owl:Class ;
                    rdfs:subClassOf [ owl:intersectionOf ( :Effect
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :affects ;
                                                             owl:hasValue :Attribute_LifeExpectancy
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :hasCost ;
                                      owl:allValuesFrom :Cost
                                    ] ;
                    rdfs:comment "Defines an 'instantaneous' death risk, e.g., a probability of dying upon the onset of a condition"@en ;
                    rdfs:label "Efecto de muerte instantánea"@es ,
                               "Instantaneous death effect"@en .


###  https://w3id.org/ontologies-ULL/OSDi#Intervention
:Intervention rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Restriction ;
                                    owl:onProperty :isAssessedIntervention ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:boolean
                                  ] ;
              rdfs:subClassOf :ModelItem ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasCategory ;
                                owl:allValuesFrom <http://www.w3.org/2004/02/skos/core#Concept>
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasCost ;
                                owl:allValuesFrom :Cost
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasEffect ;
                                owl:allValuesFrom :Effect
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasStrategy ;
                                owl:allValuesFrom :Strategy
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasUtility ;
                                owl:allValuesFrom :Utility
                              ] ;
              owl:disjointWith :ModelItemDefiningDiseaseProgression ,
                               :ModelItemWithRiskCharacterization ;
              rdfs:comment "Some kind of treatment, drug, surgical procedure... used to modify the development of a Disease. In the context of this ontology, interventions are the comparing options in the decision-making process"@en ;
              rdfs:label "Intervención"@es ,
                         "Intervention"@en .


###  https://w3id.org/ontologies-ULL/OSDi#LifeExpectancyReductionEffect
:LifeExpectancyReductionEffect rdf:type owl:Class ;
                               rdfs:subClassOf [ owl:intersectionOf ( :Effect
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty :affects ;
                                                                        owl:hasValue :Attribute_LifeExpectancy
                                                                      ]
                                                                    ) ;
                                                 rdf:type owl:Class
                                               ] ;
                               rdfs:comment "An effect that reduces the life expectancy of an individual or population."@en ;
                               rdfs:label "Efecto de reducción en la esperanza de vida"@es ,
                                          "Life expectancy reduction effect"@en .


###  https://w3id.org/ontologies-ULL/OSDi#LineOfTherapy
:LineOfTherapy rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( :Strategy
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :hasCategory ;
                                                            owl:hasValue :TreatmentCat
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:subClassOf :Strategy ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :failsIf ;
                                 owl:allValuesFrom :Parameter
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasStrategy ;
                                 owl:allValuesFrom :FollowUpStrategy
                               ] ;
               rdfs:comment "A strategy related to the treatment of a disease or condition"@es ;
               rdfs:label "Estrategia de tratamiento"@es ,
                          "Line-of-therapy strategy"@en .


###  https://w3id.org/ontologies-ULL/OSDi#Manifestation
:Manifestation rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:unionOf ( :AcuteManifestation
                                                   :ChronicManifestation
                                                 )
                                   ] ;
               rdfs:subClassOf :ClinicalProgressionElement ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasSubProgression ;
                                 owl:maxCardinality "0"^^xsd:nonNegativeInteger
                               ] ;
               owl:disjointUnionOf ( :AcuteManifestation
                                     :ChronicManifestation
                                   ) ;
               rdfs:comment "Symptoms or signs of a disease. They may be chronic or acute"@en ;
               rdfs:label "Manifestación"@es ,
                          "Manifestation"@en .


###  https://w3id.org/ontologies-ULL/OSDi#MarkovModel
:MarkovModel rdf:type owl:Class ;
             rdfs:subClassOf :Model ;
             rdfs:comment "Model based on Markov states and transitions"@en ;
             rdfs:label "Markov model"@en ,
                        "Modelo de Markov"@es .


###  https://w3id.org/ontologies-ULL/OSDi#MeasuredDataItemType
:MeasuredDataItemType rdf:type owl:Class ;
                      owl:equivalentClass [ owl:intersectionOf ( :DataItemType
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty :hasUnit ;
                                                                   owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                   owl:onDataRange xsd:string
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ] ;
                      rdfs:subClassOf :DataItemType ;
                      rdfs:comment "Type for datas items that are measureable"@en ;
                      rdfs:label "Measured data item type"@en ,
                                 "Tipo del elemento de datos medible"@es .


###  https://w3id.org/ontologies-ULL/OSDi#Model
:Model rdf:type owl:Class ;
       owl:equivalentClass [ rdf:type owl:Restriction ;
                             owl:onProperty :includesModelItem ;
                             owl:someValuesFrom :ModelItem
                           ] ;
       rdfs:subClassOf :Describable ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :usesSameModelItemsAs ;
                         owl:allValuesFrom :Model
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasAuthor ;
                         owl:someValuesFrom xsd:string
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasGeographicalContext ;
                         owl:someValuesFrom xsd:string
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasRefTo ;
                         owl:allValuesFrom xsd:string
                       ] ;
       rdfs:comment "A container to define all the items that conform a model that can be simulated"@en ;
       rdfs:label "Model"@en ,
                  "Modelo"@es .


###  https://w3id.org/ontologies-ULL/OSDi#ModelItem
:ModelItem rdf:type owl:Class ;
           owl:equivalentClass [ rdf:type owl:Restriction ;
                                 owl:onProperty :includedByModel ;
                                 owl:someValuesFrom :Model
                               ] ;
           rdfs:subClassOf :Describable ;
           rdfs:comment "Any component of a model"@en ;
           rdfs:label "Elemento del modelo"@es ,
                      "Model item"@en .


###  https://w3id.org/ontologies-ULL/OSDi#ModelItemDefiningDiseaseProgression
:ModelItemDefiningDiseaseProgression rdf:type owl:Class ;
                                     owl:equivalentClass [ owl:intersectionOf ( :ModelItem
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty :hasProgressionElement ;
                                                                                  owl:someValuesFrom :ClinicalProgressionElement
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ] ;
                                     rdfs:subClassOf :ModelItem ;
                                     owl:disjointWith :Parameter ,
                                                      :Pathway ,
                                                      :Population ,
                                                      :ProbabilityDistributionExpression ,
                                                      :ResourceUsageItem ;
                                     rdfs:comment "A model item that defines the progression of a disease"@en ;
                                     rdfs:label "Elemento del modelo definiendo progreso de la enfermedad"@es ,
                                                "Model item defining disease progression"@en .


###  https://w3id.org/ontologies-ULL/OSDi#ModelItemWithCost
:ModelItemWithCost rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( :ModelItem
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty :hasCost ;
                                                                owl:someValuesFrom :Cost
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   rdfs:subClassOf :ModelItem ;
                   owl:disjointWith :Parameter ,
                                    :Population ,
                                    :ProbabilityDistributionExpression ;
                   rdfs:comment "A model item that has at least one associated cost, i.e., it must be taken into account when computing the cost of the cost-effectiveness analysis"@en ;
                   rdfs:label "Elemento del modelo con coste"@es ,
                              "Model item with cost"@en .


###  https://w3id.org/ontologies-ULL/OSDi#ModelItemWithDetection
:ModelItemWithDetection rdf:type owl:Class ;
                        rdfs:subClassOf :ModelItem ;
                        owl:disjointWith :Parameter ,
                                         :Pathway ,
                                         :Population ,
                                         :ResourceUsageItem ,
                                         :TherapeuticIntervention ;
                        rdfs:comment "A model item that represents a detection mechanism for a disease"@en ;
                        rdfs:label "Elemento del modelo con detección"@es ,
                                   "Model item with detection"@en .


###  https://w3id.org/ontologies-ULL/OSDi#ModelItemWithEffect
:ModelItemWithEffect rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( :ModelItem
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty :hasEffect ;
                                                                  owl:someValuesFrom :Effect
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:subClassOf :ModelItem ;
                     owl:disjointWith :Parameter ,
                                      :ProbabilityDistributionExpression ;
                     rdfs:comment "A model item that has at least one associated effect"@en ;
                     rdfs:label "Elemento del modelo con efecto"@es ,
                                "Model item with effect"@en .


###  https://w3id.org/ontologies-ULL/OSDi#ModelItemWithFollowUp
:ModelItemWithFollowUp rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( :ModelItem
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :hasStrategy ;
                                                                    owl:someValuesFrom :FollowUpStrategy
                                                                  ]
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :hasStrategy ;
                                                                    owl:allValuesFrom :FollowUpStrategy
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] ;
                       rdfs:subClassOf :ModelItem ;
                       owl:disjointWith :Parameter ,
                                        :Pathway ,
                                        :Population ,
                                        :ProbabilityDistributionExpression ,
                                        :ResourceUsageItem ;
                       rdfs:comment "A model item that has at least one associated follow-up cost or strategy"@en ;
                       rdfs:label "Elemento del modelo con seguimiento"@es ,
                                  "Model item with follow-up"@en .


###  https://w3id.org/ontologies-ULL/OSDi#ModelItemWithRiskCharacterization
:ModelItemWithRiskCharacterization rdf:type owl:Class ;
                                   owl:equivalentClass [ owl:intersectionOf ( :ModelItem
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty :hasRiskCharacterization ;
                                                                                owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                     owl:unionOf ( :Parameter
                                                                                                                   :Pathway
                                                                                                                 )
                                                                                                   ]
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ] ;
                                   rdfs:subClassOf :ModelItem ;
                                   owl:disjointWith :Parameter ,
                                                    :Population ,
                                                    :ProbabilityDistributionExpression ,
                                                    :ResourceUsageItem ;
                                   rdfs:comment "A model item that has risk characterization, i.e., associated with a parameter or pathway that represents a risk factor"@en ;
                                   rdfs:label "Model item with risk characterization"@en ,
                                              "Tipo de elemento del modelo con caracterización de riesgo"@es .


###  https://w3id.org/ontologies-ULL/OSDi#ModelItemWithTemporalConstraints
:ModelItemWithTemporalConstraints rdf:type owl:Class ;
                                  owl:equivalentClass [ owl:intersectionOf ( :ModelItem
                                                                             [ rdf:type owl:Class ;
                                                                               owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty :hasDuration ;
                                                                                               owl:someValuesFrom :Parameter
                                                                                             ]
                                                                                             [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty :hasEndAge ;
                                                                                               owl:someValuesFrom :Parameter
                                                                                             ]
                                                                                             [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty :hasOnsetAge ;
                                                                                               owl:someValuesFrom :Parameter
                                                                                             ]
                                                                                           )
                                                                             ]
                                                                           ) ;
                                                        rdf:type owl:Class
                                                      ] ;
                                  rdfs:subClassOf :ModelItem ;
                                  owl:disjointWith :Parameter ,
                                                   :Pathway ,
                                                   :Population ,
                                                   :ProbabilityDistributionExpression ;
                                  rdfs:comment "A model item that has temporal constraints, i.e., duration, onset age, and end age"@en ;
                                  rdfs:label "Elemento del modelo con restricciones temporales"@es ,
                                             "Model item with temporal constraints"@en .


###  https://w3id.org/ontologies-ULL/OSDi#ModelItemWithTreatment
:ModelItemWithTreatment rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( :ModelItem
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :hasStrategy ;
                                                                     owl:someValuesFrom :LineOfTherapy
                                                                   ]
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :hasStrategy ;
                                                                     owl:allValuesFrom :LineOfTherapy
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf :ModelItem ;
                        owl:disjointWith :Parameter ,
                                         :Pathway ,
                                         :Population ,
                                         :ProbabilityDistributionExpression ,
                                         :ResourceUsageItem ;
                        rdfs:comment "A model item that has at least one associated treatment cost or line-of-therapy"@en ;
                        rdfs:label "Elemento del modelo con tratamiento"@es ,
                                   "Model item with treatment"@en .


###  https://w3id.org/ontologies-ULL/OSDi#ModelItemWithUtility
:ModelItemWithUtility rdf:type owl:Class ;
                      owl:equivalentClass [ owl:intersectionOf ( :ModelItem
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty :hasUtility ;
                                                                   owl:someValuesFrom :Utility
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ] ;
                      rdfs:subClassOf :ModelItem ;
                      owl:disjointWith :Parameter ,
                                       :ProbabilityDistributionExpression ;
                      rdfs:comment "A model item that has at least one associated utility, i.e., it must be taken into account when computing the effectiveness of the cost-effectiveness analysis"@en ;
                      rdfs:label "Elemento del modelo con utilidad"@es ,
                                 "Model item with utility"@en .


###  https://w3id.org/ontologies-ULL/OSDi#NormalDistributionExpression
:NormalDistributionExpression rdf:type owl:Class ;
                              rdfs:subClassOf :ProbabilityDistributionExpression ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty :hasRefToSTATO ;
                                                owl:hasValue "http://purl.obolibrary.org/obo/STATO_0000227"
                                              ] ;
                              rdfs:comment "Unbounded and symmetric continuous probability distribution, characterized by two parameters: average, that falls in the mode of the distribution, and standard deviation."@en ;
                              rdfs:label "Expresión para distribución de probabilidad Normal"@es ,
                                         "Expression for a Normal probability distribution"@en .


###  https://w3id.org/ontologies-ULL/OSDi#OrderedModelItem
:OrderedModelItem rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( :ModelItem
                                                             [ rdf:type owl:Class ;
                                                               owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                               owl:onProperty :hasNext ;
                                                                               owl:someValuesFrom :OrderedModelItem
                                                                             ]
                                                                             [ rdf:type owl:Restriction ;
                                                                               owl:onProperty :hasPrevious ;
                                                                               owl:someValuesFrom :OrderedModelItem
                                                                             ]
                                                                           )
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf :ModelItem ;
                  rdfs:comment "A model item that has a specific order with respect to other model items, such as the stage of a disease"@en ;
                  rdfs:label "Elemento del modelo ordenado"@es ,
                             "Ordered Model Item"@en .


###  https://w3id.org/ontologies-ULL/OSDi#Parameter
:Parameter rdf:type owl:Class ;
           rdfs:subClassOf :ModelItem ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :isAffectedBy ;
                             owl:allValuesFrom :Effect
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasDataItemType ;
                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :DataItemType
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasGeographicalContext ;
                             owl:allValuesFrom xsd:string
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasSource ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onDataRange xsd:string
                           ] ;
           rdfs:comment "Parameters used for computing outcomes or characterize certain class. They have a source, a geographical context, year, description and value"@en ;
           rdfs:label "Parameter"@en ,
                      "Parámetro"@es .


###  https://w3id.org/ontologies-ULL/OSDi#ParameterNature
:ParameterNature rdf:type owl:Class ;
                 owl:equivalentClass [ rdf:type owl:Class ;
                                       owl:unionOf ( :CalculatedParameter
                                                     :DeterministicParameter
                                                     :FirstOrderUncertaintyParameter
                                                     :SecondOrderUncertaintyParameter
                                                   )
                                     ] ;
                 rdfs:subClassOf :ModelItem ;
                 owl:disjointUnionOf ( :CalculatedParameter
                                       :DeterministicParameter
                                       :FirstOrderUncertaintyParameter
                                       :SecondOrderUncertaintyParameter
                                     ) ;
                 rdfs:comment "The nature of the values of a parameter, i.e., whether it is a constant, calculated, or characterizes uncertainty somehow. This must be used to define parameters together with 'Parameter' or any of its subclasses, i.e. an individual defining the cost of a drug should be subclass of both 'Cost' and 'DeterministicParameter'"@en ;
                 rdfs:label "Naturaleza del parámetro"@es ,
                            "Parameter nature"@en .


###  https://w3id.org/ontologies-ULL/OSDi#Pathway
:Pathway rdf:type owl:Class ;
         rdfs:subClassOf :ModelItem ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasCost ;
                           owl:allValuesFrom :Cost
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasEffect ;
                           owl:allValuesFrom :Effect
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasParameter ;
                           owl:allValuesFrom :Parameter
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasUtility ;
                           owl:allValuesFrom :Utility
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :requires ;
                           owl:allValuesFrom [ rdf:type owl:Class ;
                                               owl:unionOf ( :ClinicalProgressionElement
                                                             :Intervention
                                                           )
                                             ]
                         ] ;
         rdfs:comment "The way a disease, development, manifestation or stage appears, i.e., the conditions that must be met to lead to any of these."@en ;
         rdfs:label "Pathway"@en ,
                    "Ruta"@es .


###  https://w3id.org/ontologies-ULL/OSDi#PoissonDistributionExpression
:PoissonDistributionExpression rdf:type owl:Class ;
                               rdfs:subClassOf :ProbabilityDistributionExpression ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :hasRefToSTATO ;
                                                 owl:hasValue "http://purl.obolibrary.org/obo/STATO_0000051"
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :hasLambdaParameter ;
                                                 owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onDataRange xsd:double
                                               ] ;
                               rdfs:comment "Discrete probability distribution used to model the number of events occurring within a given time interval. It is defined by a real number (lambda)."@en ;
                               rdfs:label "Expresión para distribución de probabilidad de Poisson"@es ,
                                          "Expression for a Poisson probability distribution"@en .


###  https://w3id.org/ontologies-ULL/OSDi#Population
:Population rdf:type owl:Class ;
            rdfs:subClassOf :ModelItem ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :usesAttributeValue ;
                              owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                   owl:onProperty :isValueOfAttribute ;
                                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                   owl:onClass :Attribute
                                                 ]
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasEpidemiologicalParameter ;
                              owl:allValuesFrom [ owl:intersectionOf ( :EpidemiologicalParameter
                                                                       [ rdf:type owl:Restriction ;
                                                                         owl:onProperty :isParameterOf ;
                                                                         owl:someValuesFrom :Disease
                                                                       ]
                                                                     ) ;
                                                  rdf:type owl:Class
                                                ]
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasInitialProportion ;
                              owl:allValuesFrom :Parameter
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasParameter ;
                              owl:allValuesFrom :Parameter
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasSubpopulation ;
                              owl:allValuesFrom :Population
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasUtility ;
                              owl:allValuesFrom :Utility
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasAge ;
                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass [ rdf:type owl:Restriction ;
                                            owl:onProperty :isValueOfAttribute ;
                                            owl:hasValue :Attribute_Age
                                          ]
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasSex ;
                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass [ rdf:type owl:Restriction ;
                                            owl:onProperty :isValueOfAttribute ;
                                            owl:hasValue :Attribute_Sex
                                          ]
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasLifeExpectancy ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass [ rdf:type owl:Restriction ;
                                            owl:onProperty :isValueOfAttribute ;
                                            owl:hasValue :Attribute_LifeExpectancy
                                          ]
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :isSubpopulationOf ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass :Population
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasGeographicalContext ;
                              owl:allValuesFrom xsd:string
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasMaxAge ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onDataRange xsd:double
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasMinAge ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onDataRange xsd:double
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasSize ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onDataRange xsd:integer
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasYear ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onDataRange xsd:short
                            ] ;
            rdfs:comment "The characteristics of the population which is the objective of the assessed interventions"@en ;
            rdfs:label "Población"@es ,
                       "Population"@en .


###  https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression
:ProbabilityDistributionExpression rdf:type owl:Class ;
                                   rdfs:subClassOf :ModelItem ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :hasAverageParameter ;
                                                     owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                     owl:onDataRange xsd:double
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :hasOffsetParameter ;
                                                     owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                     owl:onDataRange xsd:double
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :hasRefToSTATO ;
                                                     owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                     owl:onDataRange xsd:string
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :hasScaleParameter ;
                                                     owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                     owl:onDataRange xsd:double
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :hasStandardDeviationParameter ;
                                                     owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                     owl:onDataRange xsd:double
                                                   ] ;
                                   rdfs:comment "An expression that defines a probablity distribution"@en ;
                                   rdfs:label "Expresión para distribución de probabilidad"@es ,
                                              "Probability distribution expression"@en .


###  https://w3id.org/ontologies-ULL/OSDi#ProgressionCombinationRule
:ProgressionCombinationRule rdf:type owl:Class ;
                            rdfs:subClassOf :DiseaseProgressionElement ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :affectsProgressionElement ;
                                              owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onClass :ClinicalProgressionElement
                                            ] ;
                            rdfs:comment "A rule that defines how to combine a set of disease progressions (exclusions, coexistence...)"@en ;
                            rdfs:label "Pogression combination rule"@en ,
                                       "Regla de combinación de progresiones"@es .


###  https://w3id.org/ontologies-ULL/OSDi#QoLDataItemType
:QoLDataItemType rdf:type owl:Class ;
                 rdfs:subClassOf :DataItemType ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasCalculationMethod ;
                                   owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                   owl:onDataRange xsd:string
                                 ] ;
                 rdfs:comment "A type of data item related to quality-of-life measures"@en ;
                 rdfs:label "Quality-of-Life Data Item Type"@en ,
                            "Tipo de elemento de datos de calidad de vida"@es .


###  https://w3id.org/ontologies-ULL/OSDi#RareDisease
:RareDisease rdf:type owl:Class ;
             rdfs:subClassOf :Disease ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasRefToGARD ;
                               owl:allValuesFrom xsd:string
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasRefToORDO ;
                               owl:allValuesFrom xsd:string
                             ] ;
             rdfs:comment "A disease with very low  prevalence"@en ;
             rdfs:label "Enfermedad rara"@es ,
                        "Rare disease"@en .


###  https://w3id.org/ontologies-ULL/OSDi#ResourceUsageItem
:ResourceUsageItem rdf:type owl:Class ;
                   rdfs:subClassOf :ModelItem ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasCategory ;
                                     owl:allValuesFrom <http://www.w3.org/2004/02/skos/core#Concept>
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasCost ;
                                     owl:allValuesFrom :Cost
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasEffect ;
                                     owl:allValuesFrom :Effect
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasGuideline ;
                                     owl:allValuesFrom :Guideline
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasUtility ;
                                     owl:allValuesFrom :Utility
                                   ] ;
                   rdfs:comment "Item related to the use of health resources, belonging to some specific category"@en ;
                   rdfs:label "Elemento de uso de recursos"@es ,
                              "Resource Usage Item"@en .


###  https://w3id.org/ontologies-ULL/OSDi#ScreeningIntervention
:ScreeningIntervention rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( :DetectionIntervention
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :hasCategory ;
                                                                    owl:hasValue :ScreeningCat
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] ;
                       rdfs:subClassOf :DetectionIntervention ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :hasTemporaryThreshold ;
                                         owl:allValuesFrom :Parameter
                                       ] ;
                       rdfs:comment "An intervention to identifiy the subset of population who may have certain disease or condition and require further testing to obtain a final diagnosis"@en ;
                       rdfs:label "Intervención de cribado"@es ,
                                  "Screening intervention"@en .


###  https://w3id.org/ontologies-ULL/OSDi#ScreeningStrategy
:ScreeningStrategy rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( :DetectionStrategy
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty :hasCategory ;
                                                                owl:hasValue :ScreeningCat
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   rdfs:subClassOf :DetectionStrategy ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasTemporaryThreshold ;
                                     owl:allValuesFrom :Parameter
                                   ] ;
                   rdfs:comment "A strategy related to the identification of persons potentially suffering a disease among a population"@en ;
                   rdfs:label "Estrategia de cribado"@es ,
                              "Screening strategy"@en .


###  https://w3id.org/ontologies-ULL/OSDi#SecondOrderUncertaintyParameter
:SecondOrderUncertaintyParameter rdf:type owl:Class ;
                                 owl:equivalentClass [ owl:intersectionOf ( :Parameter
                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty :hasUncertaintyCharacterization ;
                                                                              owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                   owl:unionOf ( :Parameter
                                                                                                                 :ProbabilityDistributionExpression
                                                                                                               )
                                                                                                 ]
                                                                            ]
                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty :hasExpectedValue ;
                                                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                              owl:onDataRange xsd:double
                                                                            ]
                                                                          ) ;
                                                       rdf:type owl:Class
                                                     ] ;
                                 rdfs:subClassOf :ParameterNature ;
                                 rdfs:comment "Parameter which value has second-order uncertainty, i.e. the precise value is not known and is subject to uncertainty. For example, the actual value of the effectiveness of a treatment could have been derived from a metaanalysis of several studies and being defined by an average but also confidence intervals"@en ;
                                 rdfs:label "Parámetro con incertidumbre de segundo orden"@es ,
                                            "Second-order uncertainty parameter"@en .


###  https://w3id.org/ontologies-ULL/OSDi#SequentialCombinationRule
:SequentialCombinationRule rdf:type owl:Class ;
                           owl:equivalentClass [ rdf:type owl:Restriction ;
                                                 owl:onProperty :hasProgressionElement ;
                                                 owl:someValuesFrom [ owl:intersectionOf ( :ClinicalProgressionElement
                                                                                           :OrderedModelItem
                                                                                         ) ;
                                                                      rdf:type owl:Class
                                                                    ]
                                               ] ;
                           rdfs:subClassOf :ProgressionCombinationRule ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :hasFirst ;
                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onClass :ClinicalProgressionElement
                                           ] ;
                           rdfs:comment "A set of disease progressions that appear sequentially, e.g., the stages of a cancer" ;
                           rdfs:label "Conjunto de progresiones de enfermedad secuenciales"@es ,
                                      "Sequential disease progression set"@en .


###  https://w3id.org/ontologies-ULL/OSDi#Stage
:Stage rdf:type owl:Class ;
       rdfs:subClassOf :ClinicalProgressionElement ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasInitialProportion ;
                         owl:allValuesFrom [ owl:intersectionOf ( :Parameter
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :isParameterOf ;
                                                                    owl:someValuesFrom :Population
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ]
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasSubProgression ;
                         owl:allValuesFrom [ owl:intersectionOf ( :ClinicalProgressionElement
                                                                  [ rdf:type owl:Class ;
                                                                    owl:complementOf :Development
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ]
                       ] ;
       rdfs:comment "A phase or step in the progression of a disease"@en ;
       rdfs:label "Estadio"@es ,
                  "Stage"@en .


###  https://w3id.org/ontologies-ULL/OSDi#Strategy
:Strategy rdf:type owl:Class ;
          rdfs:subClassOf :ResourceUsageItem ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :followedByStrategy ;
                            owl:allValuesFrom [ rdf:type owl:Class ;
                                                owl:unionOf ( :Strategy
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty :hasGroupItem ;
                                                                owl:allValuesFrom :Strategy
                                                              ]
                                                            )
                                              ]
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasConditionExpression ;
                            owl:allValuesFrom :Parameter
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :usesHealthTechnology ;
                            owl:allValuesFrom :HealthTechnology
                          ] ;
          rdfs:comment "A way of defining a series of steps required to treat, detect or follow-up a disease or condition"@es ;
          rdfs:label "Estrategia"@es ,
                     "Strategy"@en .


###  https://w3id.org/ontologies-ULL/OSDi#TherapeuticIntervention
:TherapeuticIntervention rdf:type owl:Class ;
                         owl:equivalentClass [ owl:intersectionOf ( :Intervention
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty :hasCategory ;
                                                                      owl:hasValue :TreatmentCat
                                                                    ]
                                                                  ) ;
                                               rdf:type owl:Class
                                             ] ;
                         rdfs:subClassOf :Intervention ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty :hasStrategy ;
                                           owl:allValuesFrom [ rdf:type owl:Class ;
                                                               owl:unionOf ( :FollowUpStrategy
                                                                             :LineOfTherapy
                                                                           )
                                                             ]
                                         ] ;
                         rdfs:comment "An intervention driven by a set of drugs and/or treatments"@en ;
                         rdfs:label "Intervención terapéutica"@es ,
                                    "Therapeutic intervention"@en .


###  https://w3id.org/ontologies-ULL/OSDi#UniformDistributionExpression
:UniformDistributionExpression rdf:type owl:Class ;
                               rdfs:subClassOf :ProbabilityDistributionExpression ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :hasLowerLimitParameter ;
                                                 owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onDataRange xsd:double
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :hasUpperLimitParameter ;
                                                 owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onDataRange xsd:double
                                               ] ;
                               rdfs:comment "A bounded continuous probability distribution, where the ocurrence of an event is equally probable inside the defined limits"@en ;
                               rdfs:label "Expresión para distribución de probabilidad Uniforme"@es ,
                                          "Expression for a Uniform probability distribution"@en .


###  https://w3id.org/ontologies-ULL/OSDi#Utility
:Utility rdf:type owl:Class ;
         owl:equivalentClass [ owl:intersectionOf ( :Parameter
                                                    [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                             owl:onProperty :hasDataItemType ;
                                                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                             owl:onClass :QoLDataItemType
                                                                           ]
                                                                           [ rdf:type owl:Restriction ;
                                                                             owl:onProperty :isDisutility ;
                                                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                             owl:onDataRange xsd:boolean
                                                                           ]
                                                                         ) ;
                                                      rdf:type owl:Class
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
         rdfs:subClassOf :Parameter ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :appliesOneTime ;
                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                           owl:onDataRange xsd:boolean
                         ] ;
         rdfs:comment "The self-perceived utility (or disutility) of a health state, used to compute quality-adjusted life years"@en ;
         rdfs:label "Utilidad"@es ,
                    "Utility"@en .


###  https://w3id.org/ontologies-ULL/OSDi#YearDependantParameter
:YearDependantParameter rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( :Parameter
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :hasYear ;
                                                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                     owl:onDataRange xsd:short
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf :Parameter ;
                        rdfs:comment "A parameter which value that depends on the year, such as costs"@en ;
                        rdfs:label "Parámetro dependiente del año"@es ,
                                   "Year-Dependent Parameter"@en .


