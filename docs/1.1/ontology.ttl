:Constant_Sensitivity1 rdf:type owl:NamedIndividual ,
                                :DeterministicParameter ,
                                :Parameter ;
                       :hasDataItemType :DI_Sensitivity ;
                       :hasExpectedValue "1.0"^^xsd:double .


