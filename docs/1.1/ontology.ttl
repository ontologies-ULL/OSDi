                               :EpidemiologicalParameter ;
                      :hasDataItemType :DI_Prevalence ;
                      :hasExpectedValue "1.0"^^xsd:double ;
                      :isTrueEpidemiologicalParameterEstimate "true"^^xsd:boolean .


