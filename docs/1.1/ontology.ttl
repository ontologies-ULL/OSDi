###  https://w3id.org/ontologies-ULL/OSDi#DI_BirthPrevalence
:DI_BirthPrevalence rdf:type owl:NamedIndividual ,
                             :DataItemType ;
                    :hasDescription "The proportion of a birth year cohort that has certain condition" ;
                    rdfs:label "Birth prevalence"@en ,
                               "Prevalencia al nacimiento"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DI_Continuous_Variable
:DI_Continuous_Variable rdf:type owl:NamedIndividual ,
                                 :DataItemType ;
                        :hasDescription "A data item that can take any value in a continuous range" ;
                        :hasRefToSTATO "http://purl.obolibrary.org/obo/STATO_0000251" ;
                        rdfs:label "Continuous variable"@en ,
                                   "Variable continua"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DI_Count
:DI_Count rdf:type owl:NamedIndividual ,
                   :DataItemType ;
          :hasDescription "A discrete accounting of the appearance of certain event or outcome in a population" ;
          :hasRefToSTATO "http://purl.obolibrary.org/obo/STATO_0000047" ;
          rdfs:label "Count"@en ,
                     "Cuenta"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DI_EQ5D_Utility
:DI_EQ5D_Utility rdf:type owl:NamedIndividual ,
                          :QoLDataItemType ;
                 :hasCalculationMethod "EQ-5D" .


###  https://w3id.org/ontologies-ULL/OSDi#DI_Factor
:DI_Factor rdf:type owl:NamedIndividual ,
                    :DataItemType ;
           rdfs:label "Factor"@en ,
                      "Factor"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DI_Generic_Utility
:DI_Generic_Utility rdf:type owl:NamedIndividual ,
                             :QoLDataItemType ;
                    :hasCalculationMethod "Unknown" ;
                    :hasDescription "The strength of individuals' preferences for different health states" ;
                    rdfs:comment "Generic individual to represent a utility with unknown calculation method"@en ;
                    rdfs:label "Utilidad"@es ,
                               "Utility"@en .


###  https://w3id.org/ontologies-ULL/OSDi#DI_Incidence
:DI_Incidence rdf:type owl:NamedIndividual ,
                       :DataItemType ;
              :hasDescription "The ratio of the number of new cases of a disease/manifestation/stage divided by the number of persons at risk for the disease/manifestation/stage" ;
              :hasRefToSTATO "http://purl.obolibrary.org/obo/STATO_0000413" ;
              rdfs:label "Incidence"@en ,
                         "Incidencia"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DI_Lower95ConfidenceLimit
:DI_Lower95ConfidenceLimit rdf:type owl:NamedIndividual ,
                                    :DataItemType ;
                           :hasDescription "Lower limit for a 95% Confidence interval" ;
                           :hasRefToSTATO "http://purl.obolibrary.org/obo/STATO_0000315" ;
                           rdfs:label "Limite inferior del IC al 95%"@es ,
                                      "Lower 95% CI limit"@en .


###  https://w3id.org/ontologies-ULL/OSDi#DI_MeanDifference
:DI_MeanDifference rdf:type owl:NamedIndividual ,
                            :DataItemType ;
                   :hasRefToSTATO "http://purl.obolibrary.org/obo/STATO_0000457" ;
                   rdfs:label "Diferencia de medias"@es ,
                              "Mean difference"@en .


###  https://w3id.org/ontologies-ULL/OSDi#DI_Other
:DI_Other rdf:type owl:NamedIndividual ,
                   :DataItemType ;
          :hasDescription "A data item type not explicitly defined in the ontology" ;
          rdfs:label "Other"@en ,
                     "Otro"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DI_Prevalence
:DI_Prevalence rdf:type owl:NamedIndividual ,
                        :DataItemType ;
               :hasDescription "The rratio formed by the number of subjects diagnosed with a disease or presenting certain disease progression divided by the total population size." ;
               :hasRefToSTATO "http://purl.obolibrary.org/obo/STATO_0000412" ;
               rdfs:label "Prevalence"@en ,
                          "Prevalencia"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DI_Probability
:DI_Probability rdf:type owl:NamedIndividual ,
                         :DataItemType ;
                :hasDescription "Probability of certain event" ;
                rdfs:label "Probabilidad"@es ,
                           "Probability"@en .


###  https://w3id.org/ontologies-ULL/OSDi#DI_Proportion
:DI_Proportion rdf:type owl:NamedIndividual ,
                        :DataItemType ;
               :hasDescription "The fraction of population that has certain characteristic or event" ;
               :hasRefToSTATO "http://purl.obolibrary.org/obo/STATO_0000607" ;
               rdfs:label "Proporción"@es ,
                          "Proportion"@en .


###  https://w3id.org/ontologies-ULL/OSDi#DI_Ratio
:DI_Ratio rdf:type owl:NamedIndividual ,
                   :DataItemType ;
          :hasDescription "A data item which is the quotient or r/s" ;
          :hasRefToSTATO "http://purl.obolibrary.org/obo/STATO_0000184" ;
          rdfs:label "Ratio"@en ,
                     "Razón"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DI_RelativeRisk
:DI_RelativeRisk rdf:type owl:NamedIndividual ,
                          :DataItemType ;
                 :hasRefToSTATO "http://purl.obolibrary.org/obo/STATO_0000245" ;
                 rdfs:label "Relative risk"@en ,
                            "Riesgo relativo"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DI_Sensitivity
:DI_Sensitivity rdf:type owl:NamedIndividual ,
                         :DataItemType ;
                :hasDescription "The probability of a positive test result, conditioned on the individual truly being positive" ;
                :hasRefToSTATO "http://purl.obolibrary.org/obo/STATO_0000233" ;
                rdfs:label "Sensibilidad"@es ,
                           "Sensitivity"@en .


###  https://w3id.org/ontologies-ULL/OSDi#DI_Specificity
:DI_Specificity rdf:type owl:NamedIndividual ,
                         :DataItemType ;
                :hasDescription "The probability of a negative test result, conditioned on the individual truly being negative" ;
                :hasRefToSTATO "http://purl.obolibrary.org/obo/STATO_0000134" ;
                rdfs:label "Especificidad"@es ,
                           "Specificity"@en .


###  https://w3id.org/ontologies-ULL/OSDi#DI_StandardDeviation
:DI_StandardDeviation rdf:type owl:NamedIndividual ,
                               :DataItemType ;
                      :hasDescription "A measure of variation which correspond to the average distance from the mean of the data set to any given point of that dataset" ;
                      :hasRefToSTATO "http://purl.obolibrary.org/obo/STATO_0000237" ;
                      rdfs:label "Desviación estándar"@es ,
                                 "Standard deviation"@en .


###  https://w3id.org/ontologies-ULL/OSDi#DI_TimeToEvent
:DI_TimeToEvent rdf:type owl:NamedIndividual ,
                         :MeasuredDataItemType ;
                :hasDescription "A scalar measument of the time interval until certain event happens" ;
                :hasRefToSTATO "http://purl.obolibrary.org/obo/IAO_0000416" ;
                rdfs:label "Tiempo hasta evento"@es ,
                           "Time to event"@en .


###  https://w3id.org/ontologies-ULL/OSDi#DI_Undefined
:DI_Undefined rdf:type owl:NamedIndividual ,
                       :DataItemType ;
              :hasDescription "A data item that denotes an unknown or undefined type" ;
              rdfs:label "Tipo de datos indefinido"@es ,
                         "Undefined data item type"@en .


###  https://w3id.org/ontologies-ULL/OSDi#DI_Upper95ConfidenceLimit
:DI_Upper95ConfidenceLimit rdf:type owl:NamedIndividual ,
                                    :DataItemType ;
                           :hasDescription "Upper limit for a 95% Confidence interval" ;
                           :hasRefToSTATO "http://purl.obolibrary.org/obo/STATO_0000314" ;
                           rdfs:label "Limite superior del IC al 95%"@es ,
                                      "Upper 95% CI limit"@en .


###  https://w3id.org/ontologies-ULL/OSDi#DetectionCat
:DetectionCat rdf:type owl:NamedIndividual ,
                       <http://www.w3.org/2004/02/skos/core#Concept> ;
              <http://www.w3.org/2004/02/skos/core#broader> :HealthCareCat ;
              <http://www.w3.org/2004/02/skos/core#inScheme> :ResourceUsageCategoryScheme ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "Detección"@es ,
                                                              "Detection"@en .


###  https://w3id.org/ontologies-ULL/OSDi#DiagnosisCat
:DiagnosisCat rdf:type owl:NamedIndividual ,
                       <http://www.w3.org/2004/02/skos/core#Concept> ;
              <http://www.w3.org/2004/02/skos/core#broader> :DetectionCat ;
              <http://www.w3.org/2004/02/skos/core#inScheme> :ResourceUsageCategoryScheme ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "Diagnostic"@en ,
                                                              "Diagnóstico"@es .


###  https://w3id.org/ontologies-ULL/OSDi#DrugCat
:DrugCat rdf:type owl:NamedIndividual ,
                  <http://www.w3.org/2004/02/skos/core#Concept> ;
         <http://www.w3.org/2004/02/skos/core#broader> :TreatmentCat ;
         <http://www.w3.org/2004/02/skos/core#inScheme> :ResourceUsageCategoryScheme ;
