  "@id" : "https://w3id.org/ontologies-ULL/OSDi#hasDisutilityCombinationMethod",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Defines the method used to combine disutilities in the experiment. This is useful for calculating the combined disutility of multiple health conditions or interventions in a population. The most common methods are ADD (which assumes that the disutilities are additive) and MAX (which assumes that the disutility of the combination is equal to the maximum disutility among the combined conditions or interventions)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ontologies-ULL/OSDi#Experiment"
  } ],
