}, {
  "@id" : "https://w3id.org/ontologies-ULL/OSDi#requires",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Defines that a pathway requires a certain clinical progression element or intervention. This can be useful for defining that a certain pathway requires the presence of a certain symptom or only appears when a certain intervention is applied."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ontologies-ULL/OSDi#Pathway"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "requiere"
  }, {
    "@language" : "en",
    "@value" : "requires"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "_:genid136"
  } ]
}, {
  "@id" : "https://w3id.org/ontologies-ULL/OSDi#supersedesClinicalProgression",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Defines that a clinical progression element replaces another one. This can be useful for defining that a certain manifestation replaces another one in the progression of the disease, for example, to define that a certain symptom appears after the disappearance of another symptom."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "reemplaza la progresión clínica"
  }, {
    "@language" : "en",
    "@value" : "supersedes clinical progression"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"
  } ]
}, {
  "@id" : "https://w3id.org/ontologies-ULL/OSDi#usesAttributeValue",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Defines a relationship between a disease or population and a parameter which is the value of an attribute"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "_:genid139"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "usa el valor del atributo"
  }, {
    "@language" : "en",
    "@value" : "uses attribute value"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ontologies-ULL/OSDi#AttributeValueParameter"
  } ]
}, {
  "@id" : "https://w3id.org/ontologies-ULL/OSDi#usesHealthTechnology",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Defines a relationship between a strategy and a health technology used in that strategy. This is useful for defining the health technologies used in a strategy, for example, to define that a certain drug is used in a treatment strategy or that a certain screening test is used in a screening strategy."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ontologies-ULL/OSDi#Strategy"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "uses health technology"
  }, {
    "@language" : "es",
    "@value" : "utiliza tecnología sanitaria"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ontologies-ULL/OSDi#HealthTechnology"
  } ]
}, {
  "@id" : "https://w3id.org/ontologies-ULL/OSDi#usesModel",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An experiment uses certain model"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ontologies-ULL/OSDi#Experiment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "usa el modelo"
  }, {
    "@language" : "en",
    "@value" : "uses model"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ontologies-ULL/OSDi#Model"
  } ]
}, {
  "@id" : "https://w3id.org/ontologies-ULL/OSDi#usesSameModelItemsAs",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Defines that a model uses the same data items as another model. Useful for avoiding \"recreating\" that relationship for all the model items in models which are very similar and simply difer in some characteristics."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ontologies-ULL/OSDi#Model"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "uses same model items as"
  }, {
    "@language" : "es",
    "@value" : "utiliza los mismos elementos del modelo que"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ontologies-ULL/OSDi#Model"
  } ]
} ]