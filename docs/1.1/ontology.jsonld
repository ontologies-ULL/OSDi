  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://w3id.org/ontologies-ULL/OSDi#hasParameter"
  } ]
}, {
  "@id" : "https://w3id.org/ontologies-ULL/OSDi#hasEffect",
