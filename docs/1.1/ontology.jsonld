    "@language" : "en",
    "@value" : "has disutility combination method"
  }, {
    "@language" : "es",
    "@value" : "tiene el método de combinación de disutilidades"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "_:genid148"
  } ]
}, {
  "@id" : "https://w3id.org/ontologies-ULL/OSDi#hasDose",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
