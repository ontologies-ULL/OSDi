  } ],
  "http://purl.org/dc/elements/1.1/contributor" : [ {
    "@value" : "María Luz Couce Pico (https://orcid.org/0000-0003-4861-9905)"
  } ],
  "http://purl.org/dc/elements/1.1/creator" : [ {
    "@value" : "David Prieto González (https://orcid.org/0000-0003-1411-129X)"
  }, {
    "@value" : "Evelio J. González González (https://orcid.org/0000-0002-2203-3757)"
  }, {
    "@value" : "Iván Castilla Rodríguez (http://orcid.org/0000-0003-3933-2582)"
  } ],
  "http://purl.org/dc/elements/1.1/description" : [ {
    "@language" : "en",
    "@value" : "Ontology designed for collecting and inferring the parameters required to create a simulation-based Health Technology Assesment"
  }, {
    "@language" : "es",
    "@value" : "Ontología diseñada para recopilar e inferir los parámetros necesarios para crear una evaluación de tecnología sanitaria basada en simulación"
  } ],
  "http://purl.org/dc/elements/1.1/source" : [ {
    "@id" : "https://github.com/ontologies-ULL/OSDi"
  } ],
  "http://purl.org/dc/terms/abstract" : [ {
    "@language" : "en",
    "@value" : "This ontology provides a structured framework for the interoperability of health economics data used to create models. The ontology represents all the concepts and relationships involved in health technology assessment, including the characterization of the disease and its development, the population affected, and the interventions applied."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "OSDi"
  }, {
    "@language" : "es",
    "@value" : "OSDi"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://w3id.org/ontologies-ULL/OSDi/1.1"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "1.1"
  } ]
}, {
  "@id" : "https://w3id.org/ontologies-ULL/OSDi#AcuteManifestation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Sudden or rapid appearance of clinical signs or symtoms, in general with a short and intense course"
  } ],
