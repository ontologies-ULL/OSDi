  "@id" : "https://w3id.org/ontologies-ULL/OSDi#hasEpidemiologicalParameter",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Defines an epidemiological parameter of a disease or a population, such as the incidence, prevalence, mortality, etc."
